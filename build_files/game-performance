#!/usr/bin/env bash
set -euo pipefail

profile="gaming"
use_gamemode=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--profile)
            [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 1; }
            profile="$2"
            shift 2
            ;;
        --no-gamemode)
            use_gamemode=0
            shift
            ;;
        --)
            shift
            break
            ;;
        -h|--help)
            cat >&2 <<'HELPEOF'
Usage: game-performance [options] -- <command> [args...]

Options:
  -p, --profile <gaming|performance|balanced|powersave>
      Select performance profile to apply for the duration of the command.
  --no-gamemode
      Do not wrap the command with gamemoderun.
  -h, --help
      Show this help message.
HELPEOF
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

if [[ $# -eq 0 ]]; then
    echo "Usage: game-performance [options] -- <command> [args...]" >&2
    exit 1
fi

case "$profile" in
    gaming|performance|balanced|powersave) ;;
    *)
        echo "Unsupported profile: $profile" >&2
        echo "Expected one of: gaming, performance, balanced, powersave" >&2
        exit 1
        ;;
esac

old_profile=""
restore_profile() {
    if command -v kyth-performance-mode >/dev/null 2>&1; then
        kyth-performance-mode restore >/dev/null 2>&1 || true
    fi

    if [[ -n "${old_profile}" ]] && command -v powerprofilesctl >/dev/null 2>&1; then
        powerprofilesctl set "${old_profile}" >/dev/null 2>&1 || true
    fi
}
trap restore_profile EXIT INT TERM

if command -v powerprofilesctl >/dev/null 2>&1; then
    old_profile=$(powerprofilesctl get 2>/dev/null || true)
    if [[ "${old_profile}" != "performance" ]]; then
        powerprofilesctl set performance >/dev/null 2>&1 || true
    fi
fi

if command -v kyth-performance-mode >/dev/null 2>&1; then
    kyth-performance-mode save >/dev/null 2>&1 || true
    kyth-performance-mode "$profile" >/dev/null 2>&1 || true
fi

run_cmd=("$@")
if [[ "$use_gamemode" -eq 1 ]] && command -v gamemoderun >/dev/null 2>&1; then
    run_cmd=(gamemoderun "${run_cmd[@]}")
fi

if command -v systemd-inhibit >/dev/null 2>&1; then
    systemd-inhibit \
        --what=idle:sleep \
        --why="KythOS game-performance (${profile}) session" \
        "${run_cmd[@]}"
else
    "${run_cmd[@]}"
fi
