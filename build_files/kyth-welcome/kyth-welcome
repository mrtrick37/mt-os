# ── Worker thread ──────────────────────────────────────────────────────────────
class Worker(QThread):
    line = pyqtSignal(str)
    done = pyqtSignal(int)

    def __init__(self, cmd: list[str]):
        super().__init__()
        self._cmd = cmd

    def run(self):
        try:
            proc = subprocess.Popen(
                self._cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1,
            )
            for ln in proc.stdout:
                self.line.emit(ln.rstrip())
            proc.wait()
            self.done.emit(proc.returncode)
        except Exception as exc:
            self.line.emit(f"Error: {exc}")
            self.done.emit(1)


# ── Helpers ────────────────────────────────────────────────────────────────────
@dataclass
class HardwareProbe:
    title: str
    status: str
    summary: str
    details: str
    action: str | None = None


class HardwareProbeWorker(QThread):
    done = pyqtSignal(object)
    failed = pyqtSignal(str)

    def run(self):
        try:
            self.done.emit(_collect_hardware_probes())
        except Exception as exc:
            self.failed.emit(str(exc))


def _run_command(cmd: list[str], timeout: int = 5) -> subprocess.CompletedProcess[str] | None:
    try:
        return subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=timeout,
        )
    except Exception:
        return None


def _command_stdout(cmd: list[str], timeout: int = 5) -> str:
    result = _run_command(cmd, timeout=timeout)
    if result is None:
        return ""
    return result.stdout.strip()


def _bootc_status_data() -> dict | None:
    for cmd in (["bootc", "status", "--json"], ["sudo", "-n", "bootc", "status", "--json"]):
        result = _run_command(cmd, timeout=10)
        if result is None or result.returncode != 0 or not result.stdout.strip():
            continue
        try:
            return json.loads(result.stdout)
        except json.JSONDecodeError:
            continue
    return None


def _status_palette(status: str) -> tuple[str, str, str]:
    if status == "ok":
        return ("#1f3326", "#9ece6a", "Working")
    if status == "warn":
        return ("#3a2d1d", "#e0af68", "Needs Attention")
    if status == "err":
        return ("#3a1f29", "#f7768e", "Issue Found")
    return ("#252535", "#6c7086", "Info")


def _gpu_probe(pci_text: str, lsmod_text: str) -> HardwareProbe:
    gpu_lines = [
        line.strip()
        for line in pci_text.splitlines()
        if any(token in line.lower() for token in ("vga compatible controller", "3d controller", "display controller"))
    ]
    if not gpu_lines:
        return HardwareProbe(
            "Graphics",
            "dim",
            "No GPU information detected.",
            "The helper app could not find a display adapter via lspci.",
        )

    joined = "\n".join(gpu_lines).lower()
    has_nvidia = any("nvidia" in line.lower() for line in gpu_lines)
    has_amd = any("[amd/ati]" in line.lower() or "advanced micro devices" in line.lower() for line in gpu_lines)
    has_intel = any("intel corporation" in line.lower() for line in gpu_lines)
    vendors = []
    if has_nvidia:
        vendors.append("NVIDIA")
    if has_amd:
        vendors.append("AMD")
    if has_intel:
        vendors.append("Intel")
    hybrid = len(vendors) > 1

    if has_nvidia:
        if _nvidia_module_loaded():
            summary = "Hybrid graphics detected with active NVIDIA drivers." if hybrid else "NVIDIA GPU detected with active proprietary drivers."
            details = "Detected adapters:\n" + "\n".join(gpu_lines)
            return HardwareProbe("Graphics", "ok", summary, details)
        if _akmod_nvidia_built():
            return HardwareProbe(
                "Graphics",
                "warn",
                "NVIDIA drivers are installed but not active yet.",
                "The nvidia kernel module exists for the current kernel, but it is not loaded.\n"
                "Detected adapters:\n" + "\n".join(gpu_lines),
                "Reboot to load the staged driver, then re-check this tab.",
            )
        summary = "NVIDIA hardware detected without an active proprietary driver."
        if hybrid:
            summary = "Hybrid graphics detected, but the NVIDIA driver is not active."
        return HardwareProbe(
            "Graphics",
            "err",
            summary,
            "Detected adapters:\n" + "\n".join(gpu_lines),
            "Use the NVIDIA Drivers tab to build and stage the driver.",
        )

    if has_amd:
        status = "ok" if "amdgpu" in lsmod_text.lower() else "warn"
        summary = "AMD graphics detected and the amdgpu kernel driver is loaded." if status == "ok" else "AMD graphics detected, but the amdgpu kernel driver does not appear to be loaded."
        return HardwareProbe("Graphics", status, summary, "Detected adapters:\n" + "\n".join(gpu_lines))

    if has_intel:
        intel_loaded = "i915" in lsmod_text.lower() or "\nxe " in f"\n{lsmod_text.lower()}"
        status = "ok" if intel_loaded else "warn"
        summary = "Intel graphics detected and the kernel driver is loaded." if status == "ok" else "Intel graphics detected, but no Intel graphics kernel driver was found in lsmod."
        return HardwareProbe("Graphics", status, summary, "Detected adapters:\n" + "\n".join(gpu_lines))

    return HardwareProbe("Graphics", "dim", "GPU detected, but the vendor is not recognized by the helper app yet.", "Detected adapters:\n" + joined)


def _firmware_probe() -> HardwareProbe:
    devices = _run_command(["fwupdmgr", "get-devices"], timeout=15)
    if devices is None:
        return HardwareProbe(
            "Firmware",
            "dim",
            "fwupd tools are not available.",
            "Install or enable fwupd support to inspect firmware-managed devices.",
        )
    if devices.returncode != 0:
        return HardwareProbe(
            "Firmware",
            "warn",
            "Firmware tooling is installed, but device enumeration failed.",
            devices.stdout.strip() or devices.stderr.strip() or "fwupdmgr get-devices exited with an error.",
            "Open the Firmware tab to retry and inspect the command output.",
        )

    device_count = devices.stdout.count("Device ID:")
    updates = _run_command(["fwupdmgr", "get-updates"], timeout=20)
    if updates is not None and updates.returncode == 0:
        return HardwareProbe(
            "Firmware",
            "warn",
            f"Firmware updates are available for {device_count or 'one or more'} managed device(s).",
            updates.stdout.strip() or devices.stdout.strip(),
            "Use the Firmware tab to apply updates.",
        )
    if updates is not None and updates.returncode == 2:
        return HardwareProbe(
            "Firmware",
            "ok",
            f"fwupd is managing {device_count} device(s) and reports no pending firmware updates.",
            devices.stdout.strip(),
        )
    return HardwareProbe(
        "Firmware",
        "dim",
        f"fwupd is available and detected {device_count} managed device(s).",
        devices.stdout.strip(),
        "Use the Firmware tab to refresh metadata and check for updates.",
    )


def _connectivity_probe(pci_text: str, usb_text: str) -> HardwareProbe:
    combined = "\n".join([pci_text.lower(), usb_text.lower()])
    wifi_present = any(token in combined for token in ("network controller", "wireless", "wi-fi", "802.11", "wlan"))
    bluetooth_present = "bluetooth" in combined
    rfkill = _command_stdout(["rfkill", "list"], timeout=5)
    nmcli = _command_stdout(["nmcli", "-t", "-f", "DEVICE,TYPE,STATE", "device", "status"], timeout=5)

    blocked = []
    if rfkill:
        blocks = rfkill.lower().splitlines()
        if any("soft blocked: yes" in line for line in blocks):
            blocked.append("soft-blocked")
        if any("hard blocked: yes" in line for line in blocks):
            blocked.append("hard-blocked")

    wifi_states = [line for line in nmcli.splitlines() if ":wifi:" in line]
    wifi_connected = any(":connected" in line or ":connecting" in line for line in wifi_states)

    parts = []
    if wifi_present:
        parts.append("Wi-Fi hardware detected")
    if bluetooth_present:
        parts.append("Bluetooth hardware detected")
    if not parts:
        return HardwareProbe(
            "Connectivity",
            "dim",
            "No Wi-Fi or Bluetooth hardware was detected.",
            "This may be expected on desktops or virtual machines.",
        )

    details = []
    if wifi_states:
        details.append("NetworkManager devices:\n" + "\n".join(wifi_states))
    if rfkill:
        details.append("rfkill state:\n" + rfkill)

    if blocked:
        return HardwareProbe(
            "Connectivity",
            "warn",
            f"{', '.join(parts)}; radio controls are currently {', '.join(blocked)}.",
            "\n\n".join(details) or "rfkill reports that one or more radios are blocked.",
            "Clear the rfkill block or use your laptop's wireless toggle, then refresh this tab.",
        )
    if wifi_present and not wifi_connected and wifi_states:
        return HardwareProbe(
            "Connectivity",
            "ok",
            f"{', '.join(parts)}; wireless hardware is visible and ready.",
            "\n\n".join(details) or "Wireless devices were detected successfully.",
        )
    return HardwareProbe(
        "Connectivity",
        "ok",
        f"{', '.join(parts)}; no obvious radio or driver issues were detected.",
        "\n\n".join(details) or "Wireless-related hardware looks healthy.",
    )


def _audio_probe() -> HardwareProbe:
    pipewire = _run_command(["systemctl", "--user", "is-active", "pipewire.service"], timeout=5)
    wireplumber = _run_command(["systemctl", "--user", "is-active", "wireplumber.service"], timeout=5)
    pactl_info = _run_command(["pactl", "info"], timeout=5)
    sinks = _command_stdout(["pactl", "list", "short", "sinks"], timeout=5)

    sink_count = len([line for line in sinks.splitlines() if line.strip()])
    if pactl_info is None:
        return HardwareProbe(
            "Audio",
            "dim",
            "Audio inspection tools are not available in this session.",
            "The helper app could not query pactl for sink information.",
        )

    if pactl_info.returncode != 0:
        return HardwareProbe(
            "Audio",
            "warn",
            "PipeWire or PulseAudio is not responding to pactl.",
            pactl_info.stdout.strip() or pactl_info.stderr.strip() or "pactl info returned a non-zero exit code.",
            "Log out and back in, then refresh this tab. If the issue persists, inspect the audio services.",
        )

    services = []
    if pipewire is not None and pipewire.returncode == 0:
        services.append("pipewire active")
    if wireplumber is not None and wireplumber.returncode == 0:
        services.append("wireplumber active")

    if sink_count == 0:
        return HardwareProbe(
            "Audio",
            "warn",
            "Audio services are running, but no playback sinks were detected.",
            (pactl_info.stdout.strip() + "\n\nAvailable sinks:\n" + (sinks or "none")).strip(),
            "Reconnect audio hardware or inspect your session audio configuration.",
        )

    return HardwareProbe(
        "Audio",
        "ok",
        f"Audio stack responding normally with {sink_count} playback sink(s).",
        ("Services: " + ", ".join(services) + "\n\n" if services else "") + pactl_info.stdout.strip(),
    )


def _storage_probe() -> HardwareProbe:
    usage = shutil.disk_usage("/home")
    free_percent = (usage.free / usage.total) * 100 if usage.total else 0
    trim = _run_command(["systemctl", "is-enabled", "fstrim.timer"], timeout=5)
    trim_enabled = trim is not None and trim.returncode == 0

    summary = f"/home has {free_percent:.1f}% free space remaining."
    details = (
        f"Total: {usage.total / (1024 ** 3):.1f} GiB\n"
        f"Used: {(usage.total - usage.free) / (1024 ** 3):.1f} GiB\n"
        f"Free: {usage.free / (1024 ** 3):.1f} GiB\n"
        f"TRIM timer enabled: {'yes' if trim_enabled else 'no'}"
    )
    if free_percent < 15:
        return HardwareProbe(
            "Storage",
            "warn",
            summary,
            details,
            "Free up disk space soon to avoid update and game install failures.",
        )
    return HardwareProbe("Storage", "ok", summary, details)


def _platform_probe() -> HardwareProbe:
    virt = _run_command(["systemd-detect-virt"], timeout=5)
    if virt is not None and virt.returncode == 0:
        virt_name = virt.stdout.strip() or "virtual machine"
        spice = _run_command(["systemctl", "is-active", "spice-vdagentd.service"], timeout=5)
        spice_active = spice is not None and spice.returncode == 0
        details = f"Environment: {virt_name}\nspice-vdagentd active: {'yes' if spice_active else 'no'}"
        return HardwareProbe(
            "Platform",
            "dim",
            f"Kyth is running inside {virt_name}.",
            details,
            "Some gaming and driver checks behave differently in virtual machines.",
        )
    return HardwareProbe(
        "Platform",
        "ok",
        "Bare-metal environment detected.",
        f"Current branch: {_current_branch() or 'unknown'}\nbootc staged update: {'yes' if _has_staged_update() else 'no'}",
    )


def _collect_hardware_probes() -> list[HardwareProbe]:
    pci_text = _command_stdout(["lspci"], timeout=5)
    usb_text = _command_stdout(["lsusb"], timeout=5)
    lsmod_text = _command_stdout(["lsmod"], timeout=5)
    return [
        _gpu_probe(pci_text, lsmod_text),
        _firmware_probe(),
        _connectivity_probe(pci_text, usb_text),
        _audio_probe(),
        _storage_probe(),
        _platform_probe(),
    ]


def _current_branch() -> str | None:
    """Return the image tag of the booted deployment, or None."""
    data = _bootc_status_data() or {}
    img = (
        data.get("status", {})
            .get("booted", {})
            .get("image", {})
            .get("image", {})
            .get("image", "")
    )
    if ":" in img:
        return img.split(":")[-1]
    return None


def _has_staged_update() -> bool:
    """Return True if bootc has a staged image waiting."""
    data = _bootc_status_data() or {}
    return data.get("status", {}).get("staged") is not None


def _has_rollback_deployment() -> bool:
    data = _bootc_status_data() or {}
    return data.get("status", {}).get("rollback") is not None


def _detect_nvidia() -> bool:
    try:
        r = subprocess.run(["lspci"], capture_output=True, text=True, timeout=5)
        return "nvidia" in r.stdout.lower()
    except Exception:
        return False


def _nvidia_module_loaded() -> bool:
    try:
        r = subprocess.run(["lsmod"], capture_output=True, text=True, timeout=5)
        return "nvidia" in r.stdout.lower()
    except Exception:
        return False


def _akmod_nvidia_built() -> bool:
    try:
        r = subprocess.run(
            ["modinfo", "nvidia"],
            capture_output=True, text=True, timeout=5,
        )
        return r.returncode == 0
    except Exception:
        return False


def _remove_autostart():
    path = os.path.expanduser("~/.config/autostart/kyth-welcome.desktop")
    try:
        os.remove(path)
    except OSError:
        pass


def _divider() -> QFrame:
    f = QFrame()
    f.setObjectName("divider")
    f.setFrameShape(QFrame.Shape.HLine)
    return f


# ── Hardware card ──────────────────────────────────────────────────────────────
class HardwareCard(QFrame):
    def __init__(self, probe: HardwareProbe):
        super().__init__()
        self.setObjectName("card")

        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 14, 16, 14)
        layout.setSpacing(10)

        top = QHBoxLayout()
        top.setSpacing(10)

        self._title = QLabel()
        self._title.setObjectName("card-title")
        top.addWidget(self._title)
        top.addStretch()

        self._badge = QLabel()
        self._badge.setAlignment(Qt.AlignmentFlag.AlignCenter)
        top.addWidget(self._badge)
        layout.addLayout(top)

        self._summary = QLabel()
        self._summary.setWordWrap(True)
        self._summary.setStyleSheet("color: #cdd6f4; font-weight: 600;")
        layout.addWidget(self._summary)

        self._details = QLabel()
        self._details.setObjectName("card-copy")
        self._details.setWordWrap(True)
        self._details.setTextInteractionFlags(Qt.TextInteractionFlag.TextSelectableByMouse)
        layout.addWidget(self._details)

        self._action = QLabel()
        self._action.setWordWrap(True)
        self._action.setStyleSheet("color: #7aa2f7;")
        layout.addWidget(self._action)

        self.update_probe(probe)

    def update_probe(self, probe: HardwareProbe):
        bg, fg, badge = _status_palette(probe.status)
        self._title.setText(probe.title)
        self._summary.setText(probe.summary)
        self._details.setText(probe.details)
        self._badge.setText(badge)
        self._badge.setStyleSheet(
            f"background: {bg}; color: {fg}; border-radius: 10px; padding: 4px 10px; font-weight: 600;"
        )
        if probe.action:
            self._action.setText(probe.action)
            self._action.show()
        else:
            self._action.hide()


# ── Tab: Hardware ──────────────────────────────────────────────────────────────
class HardwareTab(QWidget):
    def __init__(self):
        super().__init__()
        self._worker = None
        self._cards: list[HardwareCard] = []

        layout = QVBoxLayout(self)
        layout.setContentsMargins(40, 36, 40, 36)
        layout.setSpacing(16)

        title = QLabel("Hardware Status")
        title.setObjectName("heading")
        layout.addWidget(title)

        sub = QLabel(
            "Check graphics, firmware, connectivity, audio, storage, and platform health."
        )
        sub.setObjectName("subheading")
        sub.setWordWrap(True)
        layout.addWidget(sub)

        layout.addWidget(_divider())

        btn_row = QHBoxLayout()
        self._refresh_btn = QPushButton("Refresh Hardware Status")
        self._refresh_btn.setObjectName("primary")
        self._refresh_btn.clicked.connect(self.refresh)
        btn_row.addWidget(self._refresh_btn)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        self._status_lbl = QLabel("Running hardware probes…")
        self._status_lbl.setObjectName("subheading")
        layout.addWidget(self._status_lbl)

        self._progress = QProgressBar()
        self._progress.setRange(0, 0)
        layout.addWidget(self._progress)

        self._scroll = QScrollArea()
        self._scroll.setWidgetResizable(True)
        self._scroll.setFrameShape(QFrame.Shape.NoFrame)
        layout.addWidget(self._scroll, 1)

        self._content = QWidget()
        self._content_layout = QVBoxLayout(self._content)
        self._content_layout.setContentsMargins(0, 0, 0, 0)
        self._content_layout.setSpacing(12)
        self._scroll.setWidget(self._content)

        self.refresh()

    def refresh(self):
        self._refresh_btn.setEnabled(False)
        self._status_lbl.setText("Running hardware probes…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)
        self._progress.show()

        self._worker = HardwareProbeWorker()
        self._worker.done.connect(self._on_done)
        self._worker.failed.connect(self._on_failed)
        self._worker.start()

    def _replace_cards(self, probes: list[HardwareProbe]):
        while self._content_layout.count():
            item = self._content_layout.takeAt(0)
            widget = item.widget()
            if widget is not None:
                widget.deleteLater()

        self._cards = []
        for probe in probes:
            card = HardwareCard(probe)
            self._cards.append(card)
            self._content_layout.addWidget(card)
        self._content_layout.addStretch()

    def _on_done(self, probes: list[HardwareProbe]):
        self._progress.hide()
        self._refresh_btn.setEnabled(True)
        self._worker = None
        self._replace_cards(probes)

        levels = {probe.status for probe in probes}
        if "err" in levels:
            self._status_lbl.setText("One or more hardware issues need attention.")
            self._status_lbl.setObjectName("status-err")
        elif "warn" in levels:
            self._status_lbl.setText("Hardware looks mostly healthy, with a few items worth checking.")
            self._status_lbl.setObjectName("status-warn")
        else:
            self._status_lbl.setText("Hardware checks completed successfully.")
            self._status_lbl.setObjectName("status-ok")
