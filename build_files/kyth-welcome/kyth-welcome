        self._reboot_btn.clicked.connect(
            lambda: subprocess.Popen(["systemctl", "reboot"])
        )
        layout.addWidget(self._reboot_btn)

        layout.addStretch()

    def _run_update(self):
        self._log.clear()
        self._log.append("→ bootc upgrade\n")
        self._log.show()
        self._progress.setRange(0, 0)
        self._progress.show()
        self._status_lbl.setText("Checking for updates…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        self._reboot_btn.hide()
        self._update_btn.setEnabled(False)

        self._worker = Worker(["sudo", "bootc", "upgrade"])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_done)
        self._worker.start()

    def _on_line(self, text: str):
