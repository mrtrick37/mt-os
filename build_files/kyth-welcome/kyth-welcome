        self._status_lbl.style().polish(self._status_lbl)
        self._update_btn.setEnabled(False)
        self._check_btn.setEnabled(False)

        self._worker = Worker(["fwupdmgr", "update"])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_update_done)
        self._worker.start()

    def _on_update_done(self, code: int):
        self._progress.hide()
        self._check_btn.setEnabled(True)
        self._worker = None

        if code == 0:
            self._status_lbl.setText("Firmware updated successfully.")
            self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone. A reboot may be required.")
        else:
            self._status_lbl.setText(f"Update failed (exit code {code}).")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)

    def _on_line(self, text: str):
        self._log.append(text)
        self._log.ensureCursorVisible()


