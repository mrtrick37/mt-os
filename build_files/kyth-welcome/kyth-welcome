# ── Branch card ────────────────────────────────────────────────────────────────
class BranchCard(QFrame):
    switch_requested = pyqtSignal(str)   # emits tag

    def __init__(self, branch: dict, parent=None):
        super().__init__(parent)
        self.tag   = branch["tag"]
        self.color = branch["color"]
        self._active = False
        self.setObjectName("card")
        self.setMinimumWidth(200)

        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 14, 16, 14)
        layout.setSpacing(6)

        # Color dot + label row
        top = QHBoxLayout()
        dot = QLabel("●")
        dot.setStyleSheet(f"color: {self.color}; font-size: 16px;")
        top.addWidget(dot)

        self.lbl_label = QLabel(branch["label"])
        self.lbl_label.setObjectName("card-label")
        self.lbl_label.setStyleSheet(f"color: {self.color};")
        top.addWidget(self.lbl_label)
        top.addStretch()

        self.badge = QLabel()
        self.badge.setObjectName("badge")
        self.badge.hide()
        top.addWidget(self.badge)
        layout.addLayout(top)

        # Description
        desc = QLabel(branch["desc"])
        desc.setObjectName("card-desc")
        desc.setWordWrap(True)
        layout.addWidget(desc)

        layout.addStretch()

        # Switch button
        self.btn = QPushButton()
        self.btn.setObjectName("btn-switch")
        self.btn.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
        self.btn.clicked.connect(lambda: self.switch_requested.emit(self.tag))
        layout.addWidget(self.btn)

        self._refresh_state(False)

    def _refresh_state(self, is_active: bool):
        self._active = is_active
        self.setObjectName("card-active" if is_active else "card")
        self.style().unpolish(self)
        self.style().polish(self)

        if is_active:
            self.badge.setText("CURRENT")
            self.badge.setStyleSheet(
                f"background: rgba({self._hex_to_rgb(self.color)},0.18);"
                f"color: {self.color}; border-radius: 4px; padding: 2px 8px;"
            )
            self.badge.show()
            self.btn.setText("Up to date")
            self.btn.setStyleSheet(
                "background: #2a2e42; color: #565f89;"
            )
            self.btn.setEnabled(False)
        else:
            self.badge.hide()
            self.btn.setText("Switch to this branch")
            self.btn.setStyleSheet(
                f"background: {self.color}; color: #1e1e2e;"
            )
            self.btn.setEnabled(True)

    def mark_active(self, active: bool):
        self._refresh_state(active)

    def set_switching(self, busy: bool):
        if busy:
            self.btn.setEnabled(False)
            self.btn.setText("Switching…")
            self.btn.setStyleSheet("background: #2a2e42; color: #565f89;")
        else:
            self._refresh_state(self._active)

    @staticmethod
    def _hex_to_rgb(hex_color: str) -> str:
        h = hex_color.lstrip("#")
        r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
        return f"{r},{g},{b}"


