    def _open_terminal(self):
        for cmd in (["xdg-terminal-exec"], ["konsole"], ["xterm"]):
            if shutil.which(cmd[0]):
                try:
                    subprocess.Popen(cmd)
                    return
                except OSError:
                    pass


