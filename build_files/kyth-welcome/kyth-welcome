# ── Worker thread ──────────────────────────────────────────────────────────────
class BootcWorker(QThread):
    line     = pyqtSignal(str)
    done     = pyqtSignal(int)   # exit code

    def __init__(self, cmd):
        super().__init__()
        self.cmd = cmd

    def run(self):
        try:
            proc = subprocess.Popen(
                self.cmd,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
            )
            for ln in proc.stdout:
                self.line.emit(ln.rstrip())
            proc.wait()
            self.done.emit(proc.returncode)
        except Exception as exc:
            self.line.emit(f"ERROR: {exc}")
            self.done.emit(1)


# ── Helpers ────────────────────────────────────────────────────────────────────
def _bootc_status() -> dict | None:
    """Return parsed bootc status or None if unavailable."""
    try:
        r = subprocess.run(
            ["sudo", "bootc", "status", "--json"],
            capture_output=True, text=True, timeout=10,
        )
        if r.returncode == 0:
            return json.loads(r.stdout)
    except Exception:
        pass
    return None


def _current_ref(status: dict | None) -> str:
    """Extract the booted image ref from bootc status JSON."""
    try:
        return status["status"]["booted"]["image"]["image"]["image"]
    except (TypeError, KeyError):
        return ""


def _current_tag(ref: str) -> str:
    """Return the tag portion of an image ref, e.g. 'latest'."""
    m = re.search(r":([^:]+)$", ref)
    return m.group(1) if m else ""


def _detect_nvidia() -> bool:
    """Return True if an NVIDIA GPU is present in the system."""
    try:
        r = subprocess.run(["lspci"], capture_output=True, text=True, timeout=5)
        return "nvidia" in r.stdout.lower()
    except Exception:
        return False


def _akmod_nvidia_installed() -> bool:
    """Return True if akmod-nvidia is installed (driver source available)."""
    try:
        r = subprocess.run(
            ["rpm", "-q", "akmod-nvidia"],
            capture_output=True, text=True, timeout=5,
        )
        return r.returncode == 0
    except Exception:
        return False


def _nvidia_module_loaded() -> bool:
    """Return True if the nvidia kernel module is currently loaded."""
    try:
        r = subprocess.run(["lsmod"], capture_output=True, text=True, timeout=5)
        return "nvidia" in r.stdout.lower()
    except Exception:
        return False


