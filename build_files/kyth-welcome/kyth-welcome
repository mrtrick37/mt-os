        gh_btn.clicked.connect(
            lambda: QDesktopServices.openUrl(QUrl("https://github.com/mrtrick37/kyth"))
        )
        btn_row.addWidget(gh_btn)
        btn_row.addStretch()
        layout.addLayout(btn_row)
        layout.addStretch()
        return page

    # ── Navigation ────────────────────────────────────────────────────────────

    def _update_nav(self):
        idx = self._current
        total = len(self._steps)

        for i, dot in enumerate(self._dot_labels):
            if i < idx:
                dot.setObjectName("step-dot-done")
            elif i == idx:
                dot.setObjectName("step-dot-active")
            else:
                dot.setObjectName("step-dot-inactive")
            _restyle(dot)

        self._step_lbl.setText(
            f"{self._STEP_LABELS[idx].upper()}  ·  {idx + 1} / {total}"
        )
        self._back_btn.setVisible(idx > 0)
        self._skip_btn.setVisible(0 < idx < total - 1)

        if idx == total - 1:
            self._next_btn.setText("Close")
        elif idx == 0:
            self._next_btn.setText("Let's Go  →")
        else:
            self._next_btn.setText("Next  →")

    def _go_back(self):
        if self._current > 0:
            self._current -= 1
            self._stack.setCurrentIndex(self._current)
            self._update_nav()

    def _go_next(self):
        if self._current == len(self._steps) - 1:
            _mark_wizard_done()
            self.close()
        else:
            self._current += 1
            self._stack.setCurrentIndex(self._current)
            self._update_nav()

    def closeEvent(self, event):
        _mark_wizard_done()
        super().closeEvent(event)


# ── Entry point ───────────────────────────────────────────────────────────────
def main():
    _remove_autostart()
    _wait_for_display_setup()

    app = QApplication(sys.argv)
    app.setApplicationName("kyth-welcome")
    app.setDesktopFileName("kyth-welcome")
    app.setWindowIcon(QIcon.fromTheme("kyth"))
    app.setStyleSheet(QSS)

    win = WizardWindow() if _is_first_run() else MainWindow()
    win.setWindowIcon(QIcon.fromTheme("kyth"))
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
