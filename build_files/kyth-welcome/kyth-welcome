    def _refresh_summary(self):
        branch = _current_branch() or "unknown"
        staged = _has_staged_update()
        rollback = _has_rollback_deployment()
        if staged:
            summary = (
                f"You are on the {branch} branch. A new deployment is already downloaded and ready for your next reboot."
            )
        else:
            summary = (
                f"You are on the {branch} branch. No new deployment is staged right now."
            )
        if rollback:
            summary += " A previous deployment appears to be available if you need to roll back."
        else:
            summary += " A rollback target was not detected yet."
        self._summary_lbl.setText(summary)
        self._rollback_btn.setEnabled(rollback and self._worker is None)

    def _on_line(self, text: str):
        self._log.append(text)
        self._log.ensureCursorVisible()

    def _on_done(self, code: int):
        self._progress.hide()
        self._update_btn.setEnabled(True)
        self._rollback_btn.setEnabled(True)
        self._worker = None

        if code == 0:
            if self._mode == "rollback":
                self._status_lbl.setText("Rollback ready — reboot to return to the previous deployment.")
                self._status_lbl.setObjectName("status-warn")
                self._log.append("\nDone. Reboot when you are ready to go back to the previous system image.")
                self._reboot_btn.show()
            else:
                if _has_staged_update():
                    self._status_lbl.setText("Update ready — reboot whenever you want to start using it.")
                    self._status_lbl.setObjectName("status-ok")
                    self._log.append("\nDone. Your next system image is downloaded and waiting for the next reboot.")
                    self._reboot_btn.show()
                else:
                    self._status_lbl.setText("You are already on the newest available deployment.")
                    self._status_lbl.setObjectName("status-ok")
                    self._log.append("\nNo update was staged because this system is already current.")
        else:
            if self._mode == "rollback":
                self._status_lbl.setText(f"Rollback failed (exit code {code}).")
            else:
                self._status_lbl.setText(f"Update failed (exit code {code}).")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)
        self._refresh_summary()


