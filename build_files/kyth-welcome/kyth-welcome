    def _refresh_status(self):
        has_gpu = _detect_nvidia()
        module_loaded = _nvidia_module_loaded()
        drivers_installed = _akmod_nvidia_installed()

        if not has_gpu:
            self._lbl_sub.setText("No NVIDIA GPU detected")
            self._status_dot.setStyleSheet("color: #414868; font-size: 16px;")
            self._status_label.setText("No NVIDIA hardware found")
            self._status_label.setStyleSheet("color: #414868;")
            self._status_desc.setText(
                "No NVIDIA GPU was detected in this system. "
                "If you have an NVIDIA card, ensure it is properly seated."
            )
            self._btn_install.hide()
        elif module_loaded:
            self._lbl_sub.setText("NVIDIA GPU detected — drivers active")
            self._status_dot.setStyleSheet("color: #9ece6a; font-size: 16px;")
            self._status_label.setText("Drivers active")
            self._status_label.setStyleSheet("color: #9ece6a;")
            self._status_desc.setText(
                "The NVIDIA kernel module is loaded and active. "
                "Your GPU is ready to use."
            )
            self._btn_install.hide()
        elif drivers_installed:
            self._lbl_sub.setText("NVIDIA GPU detected — reboot required")
            self._status_dot.setStyleSheet("color: #e0af68; font-size: 16px;")
            self._status_label.setText("Drivers installed — reboot to activate")
            self._status_label.setStyleSheet("color: #e0af68;")
            self._status_desc.setText(
                "NVIDIA drivers have been compiled and installed. "
                "Reboot to load the kernel module and activate your GPU."
            )
            self._btn_install.hide()
            self._btn_reboot.show()
        else:
            self._lbl_sub.setText("NVIDIA GPU detected — drivers not installed")
            self._status_dot.setStyleSheet("color: #f7768e; font-size: 16px;")
            self._status_label.setText("Drivers not installed")
            self._status_label.setStyleSheet("color: #f7768e;")
            self._status_desc.setText(
                "An NVIDIA GPU was detected but drivers are not installed. "
                "Click below to compile and install the NVIDIA kernel module."
            )
            self._btn_install.show()

    def _set_stage(self, text: str):
        self._stage_text = text
        self._dot_count = 0
        self._lbl_stage.setText(text)

    def _tick_dots(self):
        self._dot_count = (self._dot_count + 1) % 4
        base = self._stage_text.rstrip(".")
        self._lbl_stage.setText(base + "." * self._dot_count)

    def _on_install(self):
        self._log.clear()
        self._log.append("→ Installing NVIDIA drivers…\n")
        self._btn_install.setEnabled(False)
        self._btn_reboot.hide()
        self._set_stage("Compiling kernel module…")
        self._status_widget.show()
        self._dot_timer.start()

        kargs = (
            "rd.driver.blacklist=nouveau,nova_core "
            "modprobe.blacklist=nouveau,nova_core "
            "nvidia-drm.modeset=1"
        )
        cmd = [
            "sudo", "bash", "-c",
            f"grubby --update-kernel=ALL --args='{kargs}' && "
            "akmods --force --kernels \"$(uname -r)\"",
        ]
        self._worker = BootcWorker(cmd)
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_done)
        self._worker.start()

    def _on_line(self, text: str):
        self._log.append(text)
        self._log.ensureCursorVisible()

    def _on_done(self, code: int):
        self._dot_timer.stop()
        self._btn_install.setEnabled(True)

        if code == 0:
            self._set_stage("Done — reboot to activate drivers")
            self._lbl_stage.setStyleSheet(
                "color: #9ece6a; font-size: 12px; font-weight: 600;"
            )
            self._progress.setRange(0, 1)
            self._progress.setValue(1)
            self._log.append(
                "\n✓ NVIDIA drivers installed successfully. Reboot to activate."
            )
            self._btn_reboot.show()
        else:
            self._set_stage("Installation failed")
            self._lbl_stage.setStyleSheet(
                "color: #f7768e; font-size: 12px; font-weight: 600;"
            )
            self._progress.setRange(0, 1)
            self._progress.setValue(0)
            self._log.append(
                f"\n✗ Installation failed with exit code {code}.\n"
                "Ensure akmod-nvidia is available and build tools are installed."
            )

        self._refresh_status()
        self._worker = None


