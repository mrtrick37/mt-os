    def _refresh_status(self):
        def _set_badge(lbl: QLabel, ok: bool, ok_text: str = "Installed",
                       warn_text: str = "Not Installed"):
            color = "#4dbb6f" if ok else "#555555"
            text = ok_text if ok else warn_text
            lbl.setText(f"  {text}  ")
            lbl.setStyleSheet(
                f"background: {color}22; color: {color}; border: 1px solid {color}44; "
                f"border-radius: 10px; padding: 3px 8px; font-size: 11px; font-weight: 700;"
            )

        _set_badge(self._mh_badge, _mangohud_installed())
        _set_badge(self._gs_badge, _gamescope_installed())
        _set_badge(self._vk_badge, _vkbasalt_installed())

        gp_ver = _ge_proton_version()
        _set_badge(self._gp_badge, bool(gp_ver), ok_text=gp_ver or "Installed")
        self._gp_version_lbl.setText(
            f"Installed: {gp_ver}" if gp_ver
            else "GE-Proton not found in compatibilitytools.d"
        )

        for refs in self._tool_refs:
            installed = _is_flatpak_installed(refs["tool"]["flatpak"])
            _set_badge(refs["badge"], installed)
            refs["install"].setVisible(not installed)
            refs["launch"].setVisible(installed)

