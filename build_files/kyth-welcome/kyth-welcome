# Stage labels inferred from bootc output keywords (checked in order)
_STAGE_PATTERNS = [
    (["resolving", "resolve"],                        "Resolving image…"),
    (["manifest", "fetching manifest"],               "Fetching manifest…"),
    (["pulling", "fetching", "fetch", "layer", "blob",
      "downloading", "download"],                     "Pulling image layers…"),
    (["writing", "unpacking", "unpack", "extracting"],"Writing layers to disk…"),
    (["staging", "stage", "deploying", "deploy"],     "Staging deployment…"),
    (["queued", "next boot", "complete", "done"],     "Finalising…"),
]

def _infer_stage(line: str) -> str | None:
    low = line.lower()
    for keywords, label in _STAGE_PATTERNS:
        if any(kw in low for kw in keywords):
            return label
    return None


# ── Branches page ──────────────────────────────────────────────────────────────
class BranchPage(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.setObjectName("content")
        self._worker: BootcWorker | None = None
        self._dot_timer = QTimer(self)
        self._dot_timer.setInterval(500)
        self._dot_timer.timeout.connect(self._tick_dots)
        self._dot_count = 0
        self._stage_text = ""

        root = QVBoxLayout(self)
        root.setContentsMargins(32, 28, 32, 28)
        root.setSpacing(0)

        # Title
        title = QLabel("Image Branch")
        title.setObjectName("page-title")
        root.addWidget(title)

        self.lbl_current = QLabel()
        self.lbl_current.setObjectName("page-sub")
        root.addWidget(self.lbl_current)

        root.addSpacing(6)
        root.addWidget(_sep())

        # Cards row
        card_row = QHBoxLayout()
        card_row.setSpacing(16)
        self.cards: dict[str, BranchCard] = {}
        for branch in BRANCHES:
            card = BranchCard(branch)
            card.switch_requested.connect(self._on_switch)
            card_row.addWidget(card)
            self.cards[branch["tag"]] = card
        card_row.addStretch()
        root.addLayout(card_row)

        root.addSpacing(16)

        # Note about reboot
        note = QLabel(
            "⚠  A reboot is required for the branch change to take effect."
        )
        note.setStyleSheet("color: #e0af68; font-size: 12px;")
        root.addWidget(note)

        root.addSpacing(12)

        # ── Status area (hidden while idle) ───────────────────────────────────
        self._status_widget = QWidget()
        status_layout = QVBoxLayout(self._status_widget)
        status_layout.setContentsMargins(0, 0, 0, 0)
        status_layout.setSpacing(6)

        stage_row = QHBoxLayout()
        stage_row.setSpacing(10)

        self._lbl_stage = QLabel("Preparing…")
        self._lbl_stage.setStyleSheet("color: #7aa2f7; font-size: 12px; font-weight: 600;")
        stage_row.addWidget(self._lbl_stage)
        stage_row.addStretch()
        status_layout.addLayout(stage_row)

        self._progress = QProgressBar()
        self._progress.setObjectName("switch-progress")
        self._progress.setRange(0, 0)   # indeterminate / busy
        self._progress.setFixedHeight(6)
        self._progress.setTextVisible(False)
        status_layout.addWidget(self._progress)

        self._status_widget.hide()
        root.addWidget(self._status_widget)

        root.addSpacing(12)

        # Output log
        self.log = QTextEdit()
        self.log.setObjectName("log")
        self.log.setReadOnly(True)
        self.log.setPlaceholderText("Output will appear here when switching branches…")
        self.log.setMinimumHeight(160)
        root.addWidget(self.log)

        root.addStretch()

        self._refresh_status()

    # ── helpers ───────────────────────────────────────────────────────────────

    def _set_stage(self, text: str):
        self._stage_text = text
        self._dot_count  = 0
        self._lbl_stage.setText(text)

    def _tick_dots(self):
        self._dot_count = (self._dot_count + 1) % 4
        dots = "." * self._dot_count
        # strip any trailing dots from the base label then re-add
        base = self._stage_text.rstrip(".")
        self._lbl_stage.setText(base + dots)

    def _refresh_status(self):
        status = _bootc_status()
        ref    = _current_ref(status)
        tag    = _current_tag(ref)

        if ref:
            self.lbl_current.setText(f"Current image: {ref}")
        else:
            self.lbl_current.setText("Current image: not available (live session?)")

        for t, card in self.cards.items():
            card.mark_active(t == tag)

    # ── switch flow ───────────────────────────────────────────────────────────

    def _on_switch(self, tag: str):
        ref = f"{REGISTRY}:{tag}"
        self.log.clear()
        self.log.append(f"→ sudo bootc switch {ref}\n")

        self._set_stage("Connecting to registry…")
        self._status_widget.show()
        self._dot_timer.start()

        for card in self.cards.values():
            card.set_switching(True)

        self._worker = BootcWorker(["sudo", "bootc", "switch", ref])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_done)
        self._worker.start()

    def _on_line(self, text: str):
        self.log.append(text)
        self.log.ensureCursorVisible()
        stage = _infer_stage(text)
        if stage:
            self._set_stage(stage)

    def _on_done(self, code: int):
        self._dot_timer.stop()

        if code == 0:
            self._set_stage("Done — reboot to apply")
            self._lbl_stage.setStyleSheet(
                "color: #9ece6a; font-size: 12px; font-weight: 600;"
            )
            self._progress.setRange(0, 1)
            self._progress.setValue(1)
            self.log.append(
                "\n✓ Switch staged successfully.  "
                "Reboot to boot into the new branch."
            )
        else:
            self._set_stage("Switch failed")
            self._lbl_stage.setStyleSheet(
                "color: #f7768e; font-size: 12px; font-weight: 600;"
            )
            self._progress.setRange(0, 1)
            self._progress.setValue(0)
            self.log.append(f"\n✗ bootc switch exited with code {code}.")

        for card in self.cards.values():
            card.set_switching(False)

        self._refresh_status()
        self._worker = None

        for card in self.cards.values():
            card.set_switching(False)

        self._refresh_status()
        self._worker = None


