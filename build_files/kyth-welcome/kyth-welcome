        sub = QLabel("Choose which image stream this system follows.")
        sub.setObjectName("subheading")
        layout.addWidget(sub)

        layout.addWidget(_divider())

        # Current branch label
        self._current_lbl = QLabel()
        self._current_lbl.setObjectName("subheading")
        layout.addWidget(self._current_lbl)

        # Branch buttons
        btn_row = QHBoxLayout()
        btn_row.setSpacing(12)

        self._stable_btn = QPushButton("Stable  (latest)")
        self._stable_btn.setFixedHeight(48)
        self._stable_btn.clicked.connect(lambda: self._switch("latest"))

        self._testing_btn = QPushButton("Testing")
        self._testing_btn.setFixedHeight(48)
        self._testing_btn.clicked.connect(lambda: self._switch("testing"))

        btn_row.addWidget(self._stable_btn)
        btn_row.addWidget(self._testing_btn)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        # Branch descriptions
        desc_row = QHBoxLayout()
        desc_row.setSpacing(12)
        stable_desc = QLabel("Thoroughly tested updates.\nRecommended for most users.")
        stable_desc.setObjectName("subheading")
        stable_desc.setFixedWidth(self._stable_btn.sizeHint().width())
        stable_desc.setWordWrap(True)
        testing_desc = QLabel("Latest features and changes.\nMay occasionally be unstable.")
        testing_desc.setObjectName("subheading")
        testing_desc.setWordWrap(True)
        desc_row.addWidget(stable_desc)
        desc_row.addWidget(testing_desc)
        desc_row.addStretch()
        layout.addLayout(desc_row)

        layout.addWidget(_divider())

        # Status + progress
        self._status_lbl = QLabel()
        self._status_lbl.hide()
        layout.addWidget(self._status_lbl)

        self._progress = QProgressBar()
        self._progress.setRange(0, 0)
        self._progress.hide()
        layout.addWidget(self._progress)

        self._log = QTextEdit()
        self._log.setReadOnly(True)
        self._log.setMinimumHeight(120)
        self._log.hide()
        layout.addWidget(self._log)

        # Reboot button
        self._reboot_btn = QPushButton("Reboot to Apply")
        self._reboot_btn.setObjectName("primary")
        self._reboot_btn.hide()
        self._reboot_btn.clicked.connect(
            lambda: subprocess.Popen(["systemctl", "reboot"])
        )
        layout.addWidget(self._reboot_btn)

        layout.addStretch()

        self._refresh_current()

    def _refresh_current(self):
        tag = _current_branch()
        if tag == "latest":
            self._current_lbl.setText("Currently on: Stable (latest)")
            self._stable_btn.setObjectName("branch-active")
            self._testing_btn.setObjectName("branch-inactive")
        elif tag == "testing":
            self._current_lbl.setText("Currently on: Testing")
            self._stable_btn.setObjectName("branch-inactive")
            self._testing_btn.setObjectName("branch-active")
        else:
            self._current_lbl.setText(f"Currently on: {tag or 'unknown'}")
            self._stable_btn.setObjectName("branch-inactive")
            self._testing_btn.setObjectName("branch-inactive")
        self._stable_btn.style().unpolish(self._stable_btn)
        self._stable_btn.style().polish(self._stable_btn)
        self._testing_btn.style().unpolish(self._testing_btn)
        self._testing_btn.style().polish(self._testing_btn)

    def _switch(self, tag: str):
        ref = f"{REGISTRY}:{tag}"
        self._log.clear()
        self._log.append(f"→ bootc switch {ref}\n")
        self._log.show()
        self._progress.setRange(0, 0)
        self._progress.show()
        self._status_lbl.setText("Switching branch…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        self._reboot_btn.hide()
        self._stable_btn.setEnabled(False)
        self._testing_btn.setEnabled(False)

        self._worker = Worker(["sudo", "bootc", "switch", ref])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_done)
        self._worker.start()

    def _on_line(self, text: str):
        self._log.append(text)
        self._log.ensureCursorVisible()

    def _on_done(self, code: int):
        self._progress.hide()
        self._stable_btn.setEnabled(True)
        self._testing_btn.setEnabled(True)
        self._worker = None

        if code == 0:
            self._status_lbl.setText("Branch staged — reboot to apply.")
            self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone. Reboot to boot into the new branch.")
            self._reboot_btn.show()
        else:
            self._status_lbl.setText(f"Switch failed (exit code {code}).")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)
        self._refresh_current()


