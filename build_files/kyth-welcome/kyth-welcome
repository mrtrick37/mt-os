            btn = NavButton(label)
            btn.clicked.connect(lambda _, idx=i: self._switch_page(idx))
            sidebar_layout.addWidget(btn)
            self._nav_buttons.append(btn)
            self._stack.addWidget(PageClass())

        sidebar_layout.addStretch()

        ver_lbl = QLabel(f"v{APP_VER}")
        ver_lbl.setObjectName("sidebar-version")
        sidebar_layout.addWidget(ver_lbl)

        hbox.addWidget(sidebar)
        hbox.addWidget(self._stack)

        self._switch_page(0)

    def _switch_page(self, index: int):
        self._stack.setCurrentIndex(index)
        for i, btn in enumerate(self._nav_buttons):
            btn.set_active(i == index)


# ── Entry point ────────────────────────────────────────────────────────────────
def main():
    app = QApplication(sys.argv)
    app.setApplicationName("kyth-helper")
    app.setApplicationDisplayName("Kyth")
    app.setStyleSheet(QSS)

    # Use system icon if available, otherwise skip
    icon = QIcon.fromTheme("kyth")
    if not icon.isNull():
        app.setWindowIcon(icon)

    win = MainWindow()
    win.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
