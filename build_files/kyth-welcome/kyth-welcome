        else:
            self._status_lbl.setText(f"Update failed (exit code {code}).")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)


# ── Tab: Firmware Updates ─────────────────────────────────────────────────────
class FirmwareTab(QWidget):
    def __init__(self):
        super().__init__()
        self._worker = None

        layout = QVBoxLayout(self)
        layout.setContentsMargins(40, 36, 40, 36)
        layout.setSpacing(16)

        title = QLabel("Firmware Updates")
        title.setObjectName("heading")
        layout.addWidget(title)

        sub = QLabel("Check for and install firmware updates via fwupd.")
        sub.setObjectName("subheading")
        layout.addWidget(sub)

        layout.addWidget(_divider())

        btn_row = QHBoxLayout()
        self._check_btn = QPushButton("Check for Updates")
        self._check_btn.clicked.connect(self._run_check)
        self._update_btn = QPushButton("Apply Updates")
        self._update_btn.setObjectName("primary")
        self._update_btn.setEnabled(False)
        self._update_btn.clicked.connect(self._run_update)
        btn_row.addWidget(self._check_btn)
        btn_row.addWidget(self._update_btn)
        btn_row.addStretch()
        layout.addLayout(btn_row)

        self._status_lbl = QLabel()
        self._status_lbl.hide()
        layout.addWidget(self._status_lbl)

        self._progress = QProgressBar()
        self._progress.setRange(0, 0)
        self._progress.hide()
        layout.addWidget(self._progress)

        self._log = QTextEdit()
        self._log.setReadOnly(True)
        self._log.setMinimumHeight(160)
        self._log.hide()
        layout.addWidget(self._log)

        layout.addStretch()

        note = QLabel("A reboot may be required after applying firmware updates.")
        note.setObjectName("subheading")
        note.setWordWrap(True)
        layout.addWidget(note)

    def _run_check(self):
        self._log.clear()
        self._log.append("→ fwupdmgr refresh\n")
        self._log.show()
        self._progress.setRange(0, 0)
        self._progress.show()
        self._status_lbl.setText("Refreshing firmware metadata…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.show()
        self._check_btn.setEnabled(False)
        self._update_btn.setEnabled(False)

        self._worker = Worker(["fwupdmgr", "refresh", "--force"])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_check_done)
        self._worker.start()

    def _on_check_done(self, code: int):
        self._progress.hide()
        self._check_btn.setEnabled(True)
        self._worker = None

        if code == 0:
            self._log.append("\n→ fwupdmgr get-updates\n")
            self._progress.setRange(0, 0)
            self._progress.show()
            self._status_lbl.setText("Checking for updates…")
            self._worker = Worker(["fwupdmgr", "get-updates"])
            self._worker.line.connect(self._on_line)
            self._worker.done.connect(self._on_get_updates_done)
            self._worker.start()
        else:
            self._status_lbl.setText("Failed to refresh firmware metadata.")
            self._status_lbl.setObjectName("status-err")
            self._status_lbl.style().unpolish(self._status_lbl)
            self._status_lbl.style().polish(self._status_lbl)

    def _on_get_updates_done(self, code: int):
        self._progress.hide()
        self._worker = None
        # fwupdmgr get-updates exits 2 when no updates are available
        if code == 0:
            self._status_lbl.setText("Updates available.")
            self._status_lbl.setObjectName("status-warn")
            self._update_btn.setEnabled(True)
        elif code == 2:
            self._status_lbl.setText("Firmware is up to date.")
            self._status_lbl.setObjectName("status-ok")
        else:
            self._status_lbl.setText("Could not retrieve update list.")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)

    def _run_update(self):
        self._log.append("\n→ fwupdmgr update\n")
        self._progress.setRange(0, 0)
        self._progress.show()
        self._status_lbl.setText("Applying firmware updates…")
        self._status_lbl.setObjectName("subheading")
        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)
        self._update_btn.setEnabled(False)
        self._check_btn.setEnabled(False)

        self._worker = Worker(["fwupdmgr", "update"])
        self._worker.line.connect(self._on_line)
        self._worker.done.connect(self._on_update_done)
        self._worker.start()

    def _on_update_done(self, code: int):
        self._progress.hide()
        self._check_btn.setEnabled(True)
        self._worker = None

        if code == 0:
            self._status_lbl.setText("Firmware updated successfully.")
            self._status_lbl.setObjectName("status-ok")
            self._log.append("\nDone. A reboot may be required.")
        else:
            self._status_lbl.setText(f"Update failed (exit code {code}).")
            self._status_lbl.setObjectName("status-err")

        self._status_lbl.style().unpolish(self._status_lbl)
        self._status_lbl.style().polish(self._status_lbl)

    def _on_line(self, text: str):
        self._log.append(text)
        self._log.ensureCursorVisible()


