#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/kyth/migrations"
STATE_FILE="${STATE_DIR}/local-bin-v1.done"

mkdir -p "${STATE_DIR}"

if [[ -e "${STATE_FILE}" ]]; then
    exit 0
fi

old_bins=(
    /usr/local/bin/kyth-welcome
    /usr/local/bin/game-performance
    /usr/local/bin/zink-run
    /usr/local/bin/kyth-kerver
    /usr/local/bin/kyth-device-info
    /usr/local/bin/kyth-creator-check
    /usr/local/bin/kyth-duperemove
    /usr/local/bin/kyth-set-resolution
    /usr/local/bin/kyth-set-kickoff-icon
)

for path in "${old_bins[@]}"; do
    rm -f "${path}"
done

autostarts=(
    ".config/autostart/kyth-welcome.desktop"
    ".config/autostart/kyth-set-resolution.desktop"
    ".config/autostart/kyth-set-kickoff-icon.desktop"
)

homes=(/var/home/* /root)
for home in "${homes[@]}"; do
    [[ -d "${home}" ]] || continue
    for relpath in "${autostarts[@]}"; do
        target="${home}/${relpath}"
        [[ -f "${target}" ]] || continue
        sed -i 's#/usr/local/bin/#/usr/bin/#g' "${target}"
    done
done

touch "${STATE_FILE}"
