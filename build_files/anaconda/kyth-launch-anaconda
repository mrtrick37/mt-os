#!/usr/bin/bash
# kyth-launch-anaconda — run Fedora's canonical live installer entrypoint.
# This intentionally mirrors Bazzite/Aurora behavior by deferring to liveinst,
# which in turn handles pkexec, anaconda backend startup, and webui-desktop.

set -u

RUN_ID="$(date +%Y%m%d-%H%M%S)"
LOG="/var/tmp/kyth-anaconda-${RUN_ID}.log"
LATEST_LOG="/var/tmp/kyth-anaconda.log"
HOST_DIR="/var/mnt/hostshare"
HOST_RUN_DIR=""

mkdir -p /var/tmp 2>/dev/null || true
touch "${LOG}" 2>/dev/null || true
ln -sfn "${LOG}" "${LATEST_LOG}" 2>/dev/null || true

_host_setup() {
    mkdir -p "${HOST_DIR}" 2>/dev/null || true
    if ! mountpoint -q "${HOST_DIR}" 2>/dev/null; then
        sudo -n mount -t 9p -o trans=virtio,version=9p2000.L,msize=104857600,cache=none hostshare "${HOST_DIR}" 2>/dev/null || true
    fi

    if mountpoint -q "${HOST_DIR}" 2>/dev/null && [[ -w "${HOST_DIR}" ]]; then
        HOST_RUN_DIR="${HOST_DIR}/anaconda-${RUN_ID}"
        mkdir -p "${HOST_RUN_DIR}" 2>/dev/null || true
    fi
}

_host_export_logs() {
    [[ -n "${HOST_RUN_DIR}" ]] || return 0

    {
        echo "timestamp: $(date -Is)"
        echo "host_run_dir: ${HOST_RUN_DIR}"
        echo "uid: $(id -u) user: $(id -un)"
    } > "${HOST_RUN_DIR}/export-status.txt" 2>/dev/null || true

    cp -f "${LOG}" "${HOST_RUN_DIR}/kyth-anaconda.log" 2>>"${HOST_RUN_DIR}/export-status.txt" || true

    if sudo -n test -f /tmp/anaconda.log 2>/dev/null; then
        sudo -n cat /tmp/anaconda.log > "${HOST_RUN_DIR}/anaconda.log" 2>>"${HOST_RUN_DIR}/export-status.txt" || true
    else
        echo "missing: /tmp/anaconda.log" >> "${HOST_RUN_DIR}/export-status.txt" || true
    fi

    if sudo -n test -f /tmp/anaconda-tb.txt 2>/dev/null; then
        sudo -n cat /tmp/anaconda-tb.txt > "${HOST_RUN_DIR}/anaconda-tb.txt" 2>>"${HOST_RUN_DIR}/export-status.txt" || true
    else
        echo "missing: /tmp/anaconda-tb.txt" >> "${HOST_RUN_DIR}/export-status.txt" || true
    fi

    sudo -n journalctl -b --no-pager > "${HOST_RUN_DIR}/journal-full.log" 2>>"${HOST_RUN_DIR}/export-status.txt" || true

    cp -f "${LOG}" /var/tmp/kyth-anaconda-last.log 2>/dev/null || true

    if ls "${HOST_RUN_DIR}" >/dev/null 2>&1; then
        {
            echo
            echo "files:"
            ls -l "${HOST_RUN_DIR}" 2>/dev/null || true
        } >> "${HOST_RUN_DIR}/export-status.txt" 2>/dev/null || true
    fi
}

cleanup() {
    if [[ -n "${SYNC_PID:-}" ]]; then
        kill "${SYNC_PID}" 2>/dev/null || true
    fi
    if [[ -n "${TAIL_PID:-}" ]]; then
        kill "${TAIL_PID}" 2>/dev/null || true
    fi
    if [[ -n "${IOPRI_PID:-}" ]]; then
        kill "${IOPRI_PID}" 2>/dev/null || true
    fi
    if [[ -n "${VTFIX_PID:-}" ]]; then
        kill "${VTFIX_PID}" 2>/dev/null || true
    fi
    if [[ -n "${FEEDBACK_PID:-}" ]]; then
        kill "${FEEDBACK_PID}" 2>/dev/null || true
    fi
    if [[ -n "${LOG_VIEWER_PID:-}" ]]; then
        kill "${LOG_VIEWER_PID}" 2>/dev/null || true
    fi
    _host_export_logs
}
trap cleanup EXIT

_preflight_network_check() {
    local registry="ghcr.io"
    local max_attempts=2
    local attempt=0
    local connected=false

    echo "$(date '+%T'): Pre-flight network check: testing connectivity to ${registry}" >> "${LOG}" 2>&1

    while [[ "${connected}" == "false" ]]; do
        # Try DNS resolve + TCP connect to the registry.
        if curl -sf --connect-timeout 5 --max-time 10 "https://${registry}/v2/" -o /dev/null 2>/dev/null \
           || ping -c 1 -W 3 "${registry}" >/dev/null 2>&1; then
            connected=true
            echo "$(date '+%T'): Network check passed: ${registry} is reachable." >> "${LOG}" 2>&1
            return 0
        fi

        attempt=$((attempt + 1))
        echo "$(date '+%T'): Network check attempt ${attempt}: ${registry} unreachable." >> "${LOG}" 2>&1

        # Show a dialog prompting the user to connect to WiFi.
        local dialog_text="Cannot reach the container registry (${registry}).\n\nKyth installs by downloading the OS image from the internet.\nPlease connect to a network (WiFi or Ethernet) before continuing."

        if command -v yad &>/dev/null; then
            local btn
            yad --title="Kyth Installer — Network Required" \
                --image=network-wireless \
                --text="${dialog_text}" \
                --button="Open Network Settings:2" \
                --button="Retry:0" \
                --button="Cancel Install:1" \
                --width=520 2>/dev/null
            btn=$?

            if [[ ${btn} -eq 1 ]]; then
                echo "$(date '+%T'): User cancelled install from network check dialog." >> "${LOG}" 2>&1
                exit 0
            elif [[ ${btn} -eq 2 ]]; then
                echo "$(date '+%T'): User opening network settings." >> "${LOG}" 2>&1
                # Open KDE network settings; fall back to nmtui in konsole.
                if command -v plasma-nm &>/dev/null || command -v kcmshell6 &>/dev/null; then
                    kcmshell6 kcm_networkmanagement >/dev/null 2>&1 &
                elif command -v nm-connection-editor &>/dev/null; then
                    nm-connection-editor >/dev/null 2>&1 &
                elif command -v nmtui &>/dev/null; then
                    konsole -e nmtui >/dev/null 2>&1 &
                fi
                # Give the user time to configure, then loop back to retry.
                sleep 3
            fi
            # btn==0 means Retry, just loop again.
        elif command -v kdialog &>/dev/null; then
            kdialog --title "Kyth Installer — Network Required" \
                --sorry "${dialog_text}\n\nPlease configure your network and click OK to retry." \
                2>/dev/null || { echo "$(date '+%T'): User cancelled from network dialog." >> "${LOG}" 2>&1; exit 0; }
        else
            echo "$(date '+%T'): WARNING: No dialog tool available; proceeding without network check." >> "${LOG}" 2>&1
            return 0
        fi
    done
}

_open_log_viewer() {
    # Open a Konsole window tailing installer logs so the user can monitor progress.
    # The window starts minimized to the taskbar to stay out of the way.
    local viewer_script="/var/tmp/kyth-installer-log-viewer.sh"

    cat > "${viewer_script}" << 'VIEWER'
#!/usr/bin/bash
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║              Kyth Installer — Live Log Viewer               ║"
echo "║  This window shows real-time installer activity.            ║"
echo "║  If text is scrolling, the install is working.              ║"
echo "║  Close this window at any time — it won't affect the        ║"
echo "║  installation.                                              ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""

# Wait for anaconda.log to appear (up to 60s).
for i in $(seq 1 60); do
    if sudo -n test -f /tmp/anaconda.log 2>/dev/null; then
        break
    fi
    if [ "$i" -eq 1 ]; then
        echo "Waiting for installer to start..."
    fi
    sleep 1
done

echo "--- Streaming installer logs ($(date '+%T')) ---"
echo ""
echo "[anaconda.log] Installer backend log"
echo "[journal]      System journal (bootc/ostree pull progress)"
echo ""

# Stream both anaconda.log AND the journal in parallel.
# The journal is where bootc install to-disk logs pull progress.
(
    sudo -n tail -n 20 -F /tmp/anaconda.log 2>/dev/null \
        | grep --line-buffered -Ei \
            'ostree|bootc|container|pull|deploy|install|download|layer|progress|error|warning|failed|exception|traceback|complete|finish|done|start|copying|writing|btrfs|partition|storage|payload|task' \
        | sed --unbuffered 's/^/[anaconda.log] /' &

    sudo -n journalctl -f -b 2>/dev/null \
        | grep --line-buffered -Ei \
            'bootc|ostree|container|pull|deploy|layer|download|progress|writing|btrfs|error|fatal|oom|killed|exception|segfault|transaction|copying|checkout|commit' \
        | grep --line-buffered -Ev 'pam_systemd|sudo.*COMMAND' \
        | sed --unbuffered 's/^/[journal]      /' &

    wait
) || echo "Log stream ended."

echo ""
echo "--- Log viewer finished ($(date '+%T')) ---"
echo "Press Enter to close."
read -r
VIEWER
    chmod +x "${viewer_script}"

    echo "$(date '+%T'): Opening installer log viewer (Konsole)." >> "${LOG}" 2>&1

    # --qwindowtitle sets the taskbar name; start minimized so it doesn't cover the WebUI.
    konsole --qwindowtitle "Kyth Installer Logs" \
        -e "${viewer_script}" >/dev/null 2>&1 &
    LOG_VIEWER_PID=$!
}

_browser_fallback_watchdog() {
    # If liveinst never opens the WebUI browser window, open it explicitly.
    sleep 12
    if ! pgrep -u "$(id -u)" -f '/run/user/.*/anaconda/firefox-profile' >/dev/null 2>&1; then
        {
            echo "$(date '+%T'): No Anaconda Firefox process detected after launch; starting fallback browser."
            echo "$(date '+%T'): Fallback browser cmd: /usr/bin/env MOZ_APP_TITLE= MOZ_APP_REMOTINGNAME=liveinst MOZ_GTK_TITLEBAR_DECORATION=client /usr/bin/firefox --new-instance --window-size 1024,768 --profile /run/user/$(id -u)/anaconda/firefox-profile http://127.0.0.1"
        } >> "${LOG}" 2>&1

        mkdir -p "/run/user/$(id -u)/anaconda/firefox-profile" 2>/dev/null || true
        /usr/bin/env MOZ_APP_TITLE= MOZ_APP_REMOTINGNAME=liveinst MOZ_GTK_TITLEBAR_DECORATION=client \
            /usr/bin/firefox --new-instance --window-size 1024,768 \
            --profile "/run/user/$(id -u)/anaconda/firefox-profile" http://127.0.0.1 \
            >> "${LOG}" 2>&1 &
    fi
}

_host_sync_loop() {
    [[ -n "${HOST_RUN_DIR}" ]] || return 0
    errlog="${HOST_RUN_DIR}/sync-errors.log"
    heartbeat="${HOST_RUN_DIR}/live-sync.txt"
    while :; do
        # Only replace destination files on successful source reads.
        cp -f "${LOG}" "${HOST_RUN_DIR}/kyth-anaconda.log" 2>>"${errlog}" || true

        if sudo -n test -r /tmp/anaconda.log 2>/dev/null; then
            sudo -n cat /tmp/anaconda.log > "${HOST_RUN_DIR}/anaconda.log.tmp" 2>>"${errlog}" \
                && mv -f "${HOST_RUN_DIR}/anaconda.log.tmp" "${HOST_RUN_DIR}/anaconda.log" 2>>"${errlog}" || true
        fi

        if sudo -n test -r /tmp/anaconda-tb.txt 2>/dev/null; then
            sudo -n cat /tmp/anaconda-tb.txt > "${HOST_RUN_DIR}/anaconda-tb.txt.tmp" 2>>"${errlog}" \
                && mv -f "${HOST_RUN_DIR}/anaconda-tb.txt.tmp" "${HOST_RUN_DIR}/anaconda-tb.txt" 2>>"${errlog}" || true
        fi

        sudo -n sh -c 'journalctl -b --no-pager | grep -Ei "anaconda|webui|cockpit|liveinst|ostree|bootc|traceback|exception|fatal|segfault|coredump|oom|killed|error|failed|i/o error|transaction aborted" | grep -Ev "pam_systemd\(sudo:session\): Failed to check if /run/user/0/bus exists|COMMAND=/usr/sbin/sh -c .+journalctl -b --no-pager|COMMAND=/usr/sbin/(test -r|cat) /tmp/anaconda(\.log|-tb\.txt)" | tail -n 500' > "${HOST_RUN_DIR}/journal-filtered.log.tmp" 2>>"${errlog}" \
            && mv -f "${HOST_RUN_DIR}/journal-filtered.log.tmp" "${HOST_RUN_DIR}/journal-filtered.log" 2>>"${errlog}" || true

        sudo -n dmesg -T | tail -n 300 > "${HOST_RUN_DIR}/dmesg-tail.log.tmp" 2>>"${errlog}" \
            && mv -f "${HOST_RUN_DIR}/dmesg-tail.log.tmp" "${HOST_RUN_DIR}/dmesg-tail.log" 2>>"${errlog}" || true

        printf '%s\n' "$(date -Is)" >> "${heartbeat}" 2>>"${errlog}" || true
        sleep 2
    done
}

_get_total_rx_bytes() {
    # Sum RX bytes across all non-loopback interfaces.
    awk '/:/ && !/lo:/ { gsub(/:/, " "); rx += $2 } END { print rx+0 }' /proc/net/dev
}

_human_bytes() {
    local bytes="$1"
    if (( bytes >= 1073741824 )); then
        local gb_whole=$(( bytes / 1073741824 ))
        local gb_frac=$(( (bytes % 1073741824) * 10 / 1073741824 ))
        printf '%d.%d GB' "${gb_whole}" "${gb_frac}"
    elif (( bytes >= 1048576 )); then
        printf '%d MB' $(( bytes / 1048576 ))
    elif (( bytes >= 1024 )); then
        printf '%d KB' $(( bytes / 1024 ))
    else
        printf '%d B' "${bytes}"
    fi
}

_fmt_duration() {
    local secs="$1"
    if (( secs >= 3600 )); then
        printf '%dh %dm' $((secs/3600)) $(( (secs%3600)/60 ))
    elif (( secs >= 60 )); then
        printf '%dm %ds' $((secs/60)) $((secs%60))
    else
        printf '%ds' "${secs}"
    fi
}

_install_progress_monitor() {
    # Persistent yad window showing live download progress.
    # Monitors network throughput to estimate download progress since bootc
    # doesn't provide per-layer progress output.

    local start_ts rx_start rx_now rx_prev speed downloaded elapsed
    local total_size_label=""
    local phase="waiting"
    local fifo="/var/tmp/kyth-progress-fifo.$$"
    local bootc_pid=""

    mkfifo "${fifo}" 2>/dev/null || return 0

    # Launch yad text-info window reading from the FIFO.
    yad --text-info --tail \
        --title="Kyth Installation Progress" \
        --width=500 --height=340 \
        --no-buttons \
        --fontname="Monospace 10" \
        --back="#1a1b26" --fore="#a9b1d6" \
        < "${fifo}" &
    local yad_pid=$!

    # Write status updates to the FIFO.
    {
        echo "  Kyth OS Installation"
        echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "  Waiting for image download to start..."
        echo ""

        # Wait for bootc to appear in the journal (up to 120s).
        for _i in $(seq 1 60); do
            if sudo -n journalctl -b --no-pager 2>/dev/null | grep -q 'layers.*needed.*GB\|layers.*needed.*MB'; then
                total_size_label=$(sudo -n journalctl -b --no-pager 2>/dev/null \
                    | grep -oP 'layers needed: \d+ \(\K[^)]+' | tail -1)
                # Also try to get the bootc PID.
                bootc_pid=$(pgrep -f 'ostree container image deploy' 2>/dev/null | head -1 || true)
                phase="downloading"
                break
            fi
            # Check if install already finished while we were waiting.
            if sudo -n journalctl -b --no-pager 2>/dev/null | grep -q 'All tasks in the installation queue are done'; then
                phase="done"
                break
            fi
            sleep 2
        done

        if [[ "${phase}" == "done" ]]; then
            echo "  Installation complete!"
            sleep 5
        elif [[ "${phase}" == "waiting" ]]; then
            echo "  Could not detect download start."
            echo "  Check the log viewer for details."
            sleep 10
        else
            start_ts=$(date +%s)
            rx_start=$(_get_total_rx_bytes)
            rx_prev=${rx_start}

            echo "  Downloading Kyth OS image${total_size_label:+ ($total_size_label)}"
            echo "  This typically takes 10-30 minutes on broadband,"
            echo "  or longer on slower connections."
            echo ""
            echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

            while :; do
                # Check if download/install finished.
                if [[ -n "${bootc_pid}" ]] && ! kill -0 "${bootc_pid}" 2>/dev/null; then
                    # bootc process ended — check if more tasks are running.
                    if sudo -n journalctl -b --no-pager 2>/dev/null | grep -q 'All tasks in the installation queue are done'; then
                        phase="done"
                    else
                        phase="post-download"
                    fi
                    break
                fi

                rx_now=$(_get_total_rx_bytes)
                elapsed=$(( $(date +%s) - start_ts ))
                downloaded=$(( rx_now - rx_start ))
                speed=$(( (rx_now - rx_prev) / 3 ))  # bytes/sec (sampled over 3s)
                rx_prev=${rx_now}

                # Build status line (overwrites are not possible in yad --text-info,
                # so print a compact update line every interval).
                printf '  %s elapsed | %s downloaded | %s/s\n' \
                    "$(_fmt_duration ${elapsed})" \
                    "$(_human_bytes ${downloaded})" \
                    "$(_human_bytes ${speed})"

                sleep 3
            done

            echo ""
            echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            if [[ "${phase}" == "done" ]]; then
                elapsed=$(( $(date +%s) - start_ts ))
                downloaded=$(( $(_get_total_rx_bytes) - rx_start ))
                echo "  Installation complete!"
                echo "  Downloaded $(_human_bytes ${downloaded}) in $(_fmt_duration ${elapsed})"
            else
                echo "  Download complete — finalizing installation..."
                # Wait for the rest of the install tasks.
                for _w in $(seq 1 300); do
                    if sudo -n journalctl -b --no-pager 2>/dev/null | grep -q 'All tasks in the installation queue are done'; then
                        echo "  Installation complete!"
                        break
                    fi
                    sleep 2
                done
            fi
            echo ""
            echo "  You can close this window."
            sleep 30
        fi
    } > "${fifo}" 2>/dev/null

    rm -f "${fifo}" 2>/dev/null || true
    kill "${yad_pid}" 2>/dev/null || true
}

_active_vt() {
    local vt
    vt=$(fgconsole 2>/dev/null || true)
    if [[ -z "${vt}" && -r /sys/class/tty/tty0/active ]]; then
        vt=$(tr -d '[:space:]' < /sys/class/tty/tty0/active)
        vt=${vt#tty}
    fi
    printf '%s' "${vt}"
}

_keep_installer_vt_foreground_loop() {
    local target_vt="$1"
    [[ -n "${target_vt}" ]] || return 0

    while :; do
        local current_vt
        current_vt=$(_active_vt)
        if [[ -n "${current_vt}" && "${current_vt}" != "${target_vt}" ]]; then
            echo "$(date '+%T'): VT guard: active tty${current_vt}; switching back to tty${target_vt}." >> "${LOG}" 2>&1
            sudo -n chvt "${target_vt}" >/dev/null 2>&1 || true
        fi
        sleep 2
    done
}

_die() {
    echo "$(date '+%T'): ERROR: $*" | tee -a "${LOG}"
    {
        echo
        echo "===== Kyth anaconda diagnostics ====="
        echo "timestamp: $(date -Is)"
        echo "uid: $(id -u) user: $(id -un)"
        echo "cmdline: $(cat /proc/cmdline 2>/dev/null || true)"
        echo
        echo "--- ls -l /tmp/anaconda* ---"
        ls -l /tmp/anaconda* 2>/dev/null || echo "no /tmp/anaconda* files"
        echo
        echo "--- /tmp/anaconda.log (tail -300, sudo) ---"
        sudo -n sh -c 'tail -n 300 /tmp/anaconda.log' 2>&1 || true
        echo
        echo "--- /tmp/anaconda-tb.txt (sudo) ---"
        sudo -n sh -c 'cat /tmp/anaconda-tb.txt' 2>&1 || true
        echo
        echo "--- journalctl -b (anaconda/liveinst/webui) ---"
        sudo -n sh -c 'journalctl -b --no-pager | grep -Ei "anaconda|liveinst|webui|cockpit-ws|traceback|exception" | tail -n 300' 2>&1 || true
        echo "===== End diagnostics ====="
        echo
    } >> "${LOG}" 2>&1
    if command -v yad &>/dev/null; then
        yad --error --title="Kyth Installer" \
            --text="$*\n\nFull log: ${LOG}" \
            --width=500 2>/dev/null || true
    fi
    exit 1
}

_prompt_reboot() {
    local prompt_text="Installation finished.\n\nReboot now to boot into the installed system?"

    if command -v yad &>/dev/null; then
        if yad --question \
            --title="Kyth Installer" \
            --text="$prompt_text" \
            --button="Reboot now:0" \
            --button="Stay on desktop:1" \
            --width=520 2>/dev/null; then
            return 0
        fi
        return 1
    fi

    if command -v kdialog &>/dev/null; then
        if kdialog --title "Kyth Installer" --yes-label "Reboot now" --no-label "Stay on desktop" --yesno "$prompt_text" 2>/dev/null; then
            return 0
        fi
        return 1
    fi

    echo "$(date '+%T'): No dialog tool available for reboot prompt; staying on desktop by default." | tee -a "${LOG}"
    return 1
}

_is_benign_liveinst_rc1() {
    # Layer 1: known WebUI teardown signature after successful install.
    if sudo -n test ! -s /tmp/anaconda-tb.txt 2>/dev/null \
        && sudo -n grep -Fq 'web-ui: the webui-desktop script ended abruptly!' /tmp/anaconda.log 2>/dev/null \
        && sudo -n grep -Fq 'web-ui: cockpit web view has finished running' /tmp/anaconda.log 2>/dev/null; then
        echo "$(date '+%T'): rc=1 classifier layer-1 matched (known WebUI teardown signature)." >> "${LOG}" 2>&1
        return 0
    fi

    # Layer 2: journal-backed success path for Exit-to-Desktop. This catches
    # minor log wording drift while still requiring no traceback.
    if sudo -n test ! -s /tmp/anaconda-tb.txt 2>/dev/null \
        && sudo -n journalctl -b --no-pager | grep -Fq 'All tasks in the installation queue are done. Installation successfully finished.' 2>/dev/null \
        && sudo -n journalctl -b --no-pager | grep -Fq 'Exit called with RebootData(action=-1' 2>/dev/null; then
        echo "$(date '+%T'): rc=1 classifier layer-2 matched (install-finished + exit-to-desktop markers)." >> "${LOG}" 2>&1
        return 0
    fi

    return 1
}

LIVEINST_BIN=""
for _p in /usr/bin/liveinst /usr/sbin/liveinst; do
    [[ -x "${_p}" ]] && LIVEINST_BIN="${_p}" && break
done
[[ -n "${LIVEINST_BIN}" ]] || _die "liveinst not found — is anaconda-live installed?"

_host_setup
_host_sync_loop &
SYNC_PID=$!

if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
    _die "No graphical session detected (DISPLAY/WAYLAND_DISPLAY missing)."
fi

# ── Pre-flight: ensure network connectivity before starting the installer ──
_preflight_network_check

{
    echo "$(date '+%T'): Launcher env: DISPLAY=${DISPLAY:-<unset>} WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-<unset>} XAUTHORITY=${XAUTHORITY:-<unset>}"
    echo "$(date '+%T'): Launcher env: PKEXEC_UID=${PKEXEC_UID:-<unset>} PKEXEC_USER=${PKEXEC_USER:-<unset>}"
    if [[ -n "${HOST_RUN_DIR}" ]]; then
        echo "$(date '+%T'): Host log export enabled: ${HOST_RUN_DIR}"
    else
        echo "$(date '+%T'): Host log export disabled: /var/mnt/hostshare not mounted/writable"
    fi
} >> "${LOG}" 2>&1

# Avoid inheriting broken empty PKEXEC variables into liveinst. pkexec will set
# correct values when it re-execs as root.
unset PKEXEC_UID PKEXEC_USER

# Use software rendering for installer UI by default on live media.
# This avoids known AMD+installer browser crashes on some bare-metal laptops.
# Advanced override for diagnostics: pass kyth.installer.hwgl=1 to keep HW GL.
if grep -qw 'kyth.installer.hwgl=1' /proc/cmdline 2>/dev/null; then
    echo "$(date '+%T'): Installer hardware GL override enabled via kernel arg (kyth.installer.hwgl=1)." >> "${LOG}" 2>&1
else
    export LIBGL_ALWAYS_SOFTWARE=1
    export GALLIUM_DRIVER=llvmpipe
    export MESA_LOADER_DRIVER_OVERRIDE=llvmpipe
    export QT_QUICK_BACKEND=software
    echo "$(date '+%T'): Installer software rendering enabled (default)." >> "${LOG}" 2>&1
fi

# Disable Firefox WebRender (GPU compositor) for the installer session.
# Mesa-git on bare-metal AMD can crash during WebUI form rendering (text input
# fields on the accounts spoke). QEMU's virtio-gpu is unaffected because it
# uses a different driver path.  MOZ_WEBRENDER=0 falls back to the stable
# software compositor while keeping the rest of the desktop GPU-accelerated.
export MOZ_WEBRENDER=0
export MOZ_X11_EGL=0
export MOZ_DISABLE_RDD_SANDBOX=1

# Stream backend logs live so failures are visible before liveinst exits.
{
    echo "$(date '+%T'): Starting live backend log stream (/tmp/anaconda.log, /tmp/anaconda-tb.txt)"
    sudo -n sh -c 'touch /tmp/anaconda.log /tmp/anaconda-tb.txt; tail -n +1 -F /tmp/anaconda.log /tmp/anaconda-tb.txt'
} >> "${LOG}" 2>&1 &
TAIL_PID=$!

# ── Open log viewer alongside installer ────────────────────────────────────
_open_log_viewer

echo "$(date '+%T'): Launching Fedora liveinst (${LIVEINST_BIN})" | tee -a "${LOG}"
# Optional browser watchdog for diagnostics and slow startup edge cases.
if grep -qw 'kyth.installer.browser_watchdog=1' /proc/cmdline 2>/dev/null; then
    _browser_fallback_watchdog &
    FALLBACK_PID=$!
else
    echo "$(date '+%T'): Browser watchdog disabled (default)." >> "${LOG}" 2>&1
fi
INSTALLER_VT=$(_active_vt)
# Optional VT guard for kiosks/lab runs.
# Disabled by default so users can switch to tty2/tty3 for crash triage.
if grep -qw 'kyth.installer.vtguard=1' /proc/cmdline 2>/dev/null; then
    if [[ -n "${INSTALLER_VT}" ]]; then
        echo "$(date '+%T'): Installer started on tty${INSTALLER_VT}; VT guard enabled via kernel arg." >> "${LOG}" 2>&1
        _keep_installer_vt_foreground_loop "${INSTALLER_VT}" &
        VTFIX_PID=$!
    else
        echo "$(date '+%T'): VT guard requested but active tty not detected." >> "${LOG}" 2>&1
    fi
else
    echo "$(date '+%T'): VT guard disabled (default)." >> "${LOG}" 2>&1
fi
# Background loop: continuously deprioritize anaconda/ostree child processes
# so the desktop (Xorg, plasmashell) stays responsive during the multi-GB
# ostree pull.  ionice on the parent alone doesn't propagate to grandchildren
# spawned by anaconda, and liveinst runs as root via pkexec so sudo is needed.
_io_deprioritize_loop() {
    sleep 10  # wait for anaconda to spawn
    while true; do
        for pid in $(sudo -n pgrep -f 'anaconda|ostree-container|bootc' 2>/dev/null); do
            sudo -n ionice -c 3 -p "$pid" 2>/dev/null || true
            sudo -n renice -n 15 -p "$pid" >/dev/null 2>&1 || true
        done
        sleep 5
    done
}
if grep -qw 'kyth.installer.iotune=1' /proc/cmdline 2>/dev/null; then
    _io_deprioritize_loop &
    IOPRI_PID=$!
else
    echo "$(date '+%T'): Installer I/O tuning loop disabled (default)." >> "${LOG}" 2>&1
fi

# Persistent progress window: shows download speed and estimated progress.
# Opt-out with kernel arg kyth.installer.noprogress=1.
if grep -qw 'kyth.installer.noprogress=1' /proc/cmdline 2>/dev/null; then
    echo "$(date '+%T'): Installer progress window disabled via kernel arg (kyth.installer.noprogress=1)." >> "${LOG}" 2>&1
elif command -v yad &>/dev/null; then
    _install_progress_monitor &
    FEEDBACK_PID=$!
else
    echo "$(date '+%T'): yad not available — progress window skipped." >> "${LOG}" 2>&1
fi

"${LIVEINST_BIN}" >>"${LOG}" 2>&1
rc=$?

if [[ -n "${FALLBACK_PID:-}" ]]; then
    kill "${FALLBACK_PID}" 2>/dev/null || true
fi
if [[ -n "${VTFIX_PID:-}" ]]; then
    kill "${VTFIX_PID}" 2>/dev/null || true
fi
if [[ -n "${FEEDBACK_PID:-}" ]]; then
    kill "${FEEDBACK_PID}" 2>/dev/null || true
fi

{
    echo
    echo "===== liveinst exit summary ====="
    echo "timestamp: $(date -Is)"
    echo "liveinst rc: ${rc}"
    echo "--- /tmp/anaconda.log (tail -200, sudo) ---"
    sudo -n sh -c 'tail -n 200 /tmp/anaconda.log' 2>&1 || true
    echo "--- /tmp/anaconda-tb.txt (sudo) ---"
    sudo -n sh -c 'cat /tmp/anaconda-tb.txt' 2>&1 || true
    echo "===== end summary ====="
    echo
} >> "${LOG}" 2>&1

if [[ $rc -ne 0 ]]; then
    if [[ $rc -eq 1 ]] && _is_benign_liveinst_rc1; then
        echo "$(date '+%T'): WARNING: liveinst exited with rc=1 but matched benign post-install teardown classifier; treating as successful exit-to-desktop." | tee -a "${LOG}"
        rc=0
    fi
fi

if [[ $rc -ne 0 ]]; then
    _die "Anaconda exited with error code ${rc}. Check ${LOG} for details."
fi

echo "$(date '+%T'): Anaconda exited cleanly." | tee -a "${LOG}"

if _prompt_reboot; then
    echo "$(date '+%T'): User chose reboot after installation." | tee -a "${LOG}"
    # Clear the screen and show a clean message while the system reboots.
    # This prevents the raw console/journal output from flashing on screen
    # between the desktop tearing down and the kernel rebooting.
    if command -v plymouth &>/dev/null && sudo -n plymouth --ping 2>/dev/null; then
        sudo -n plymouth display-message --text="Rebooting into Kyth..." 2>/dev/null || true
    fi
    # Switch to a blank VT to hide desktop teardown artifacts.
    sudo -n sh -c 'clear >/dev/tty1 2>/dev/null; chvt 1 2>/dev/null' || true
    if ! sudo -n env KYTH_REAL_SYSTEMCTL=/usr/bin/systemctl KYTH_INSTALL_SUCCESS=1 /usr/bin/kyth-systemctl-wrapper reboot; then
        echo "$(date '+%T'): ERROR: Failed to trigger reboot via systemctl." | tee -a "${LOG}"
        if command -v yad &>/dev/null; then
            yad --error --title="Kyth Installer" \
                --text="Failed to trigger reboot automatically.\n\nPlease reboot manually from the system menu." \
                --width=520 2>/dev/null || true
        fi
    fi
else
    echo "$(date '+%T'): User chose to stay on desktop after installation." | tee -a "${LOG}"
fi
