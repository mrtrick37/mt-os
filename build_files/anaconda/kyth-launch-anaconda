#!/usr/bin/bash
# kyth-launch-anaconda — launch Anaconda WebUI from the live KDE desktop.
#
# Architecture (replicates what cockpit-desktop does):
#   1. Start cockpit-ws in local-session mode — no TLS, no login screen
#   2. Start anaconda via liveinst (the installation backend)
#   3. Open Firefox in kiosk mode directly to the anaconda WebUI page
#
# cockpit-ws --local-session runs cockpit-bridge directly as the session,
# bypassing PAM authentication entirely.  anaconda-webui (a cockpit plugin
# installed at /usr/share/cockpit/anaconda-webui/) talks to the anaconda
# backend over D-Bus through cockpit-bridge.

LOG="${XDG_RUNTIME_DIR:-/tmp}/kyth-anaconda.log"
COCKPIT_PORT=9090
COCKPIT_URL="http://localhost:${COCKPIT_PORT}/anaconda"

_die() {
    echo "$(date '+%T'): ERROR: $*" | tee -a "${LOG}"
    if command -v yad >/dev/null 2>&1; then
        yad --error --title="Kyth Installer" \
            --text="$*\n\nFull log: ${LOG}" \
            --width=500 2>/dev/null || true
    fi
    exit 1
}

_cleanup() {
    [[ -n "${COCKPIT_PID:-}" ]] && kill "${COCKPIT_PID}" 2>/dev/null || true
    [[ -n "${LIVEINST_PID:-}" ]] && kill "${LIVEINST_PID}" 2>/dev/null || true
}
trap _cleanup EXIT

# ── Locate liveinst ───────────────────────────────────────────────────────────
LIVEINST_BIN=""
for _p in /usr/sbin/liveinst /usr/bin/liveinst; do
    if [[ -x "${_p}" ]]; then
        LIVEINST_BIN="${_p}"
        break
    fi
done
[[ -n "${LIVEINST_BIN}" ]] || _die "liveinst not found — is anaconda-live installed?"

# ── Stop any pre-existing cockpit instance ────────────────────────────────────
# cockpit.socket starts cockpit-ws in server mode (requires login).
# We need local-session mode instead, so make sure nothing is on our port.
sudo -n systemctl stop cockpit.socket cockpit.service 2>/dev/null || true

# ── Start cockpit-ws in local-session mode (no auth, no TLS) ──────────────────
# This is what cockpit-desktop does under the hood.  --local-session forks
# cockpit-bridge as a direct child, giving the browser full system access
# without any PAM/login dialog.
echo "$(date '+%T'): Starting cockpit-ws (local session, port ${COCKPIT_PORT})..." | tee -a "${LOG}"
sudo -n cockpit-ws \
    --no-tls \
    --port "${COCKPIT_PORT}" \
    --local-session=cockpit-bridge >>"${LOG}" 2>&1 &
COCKPIT_PID=$!

# Wait for cockpit-ws to bind (up to 15s)
_ready=0
for _i in $(seq 1 15); do
    if ! kill -0 "${COCKPIT_PID}" 2>/dev/null; then
        _die "cockpit-ws exited unexpectedly — check ${LOG}"
    fi
    if ss -tlnp 2>/dev/null | grep -q ":${COCKPIT_PORT}"; then
        _ready=1
        break
    fi
    sleep 1
done
[[ "${_ready}" == "1" ]] || _die "cockpit-ws did not bind :${COCKPIT_PORT} within 15s — check ${LOG}"
echo "$(date '+%T'): cockpit-ws ready on :${COCKPIT_PORT}" | tee -a "${LOG}"

# ── Start Anaconda via liveinst ───────────────────────────────────────────────
# liveinst starts anaconda which exposes its D-Bus interface on the system bus.
# anaconda-webui (served by our cockpit-ws) communicates with it via
# cockpit-bridge → D-Bus.
#
# Do NOT pass DBUS_SESSION_BUS_ADDRESS — anaconda runs as root and cannot
# access liveuser's session bus (crashes in inhibit_screensaver).
echo "$(date '+%T'): Starting liveinst (${LIVEINST_BIN})..." | tee -a "${LOG}"
sudo -n \
    DISPLAY="${DISPLAY:-}" \
    XAUTHORITY="${XAUTHORITY:-}" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
    XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-x11}" \
    "${LIVEINST_BIN}" >>"${LOG}" 2>&1 &
LIVEINST_PID=$!

# Brief pause to let anaconda initialise before the browser connects
sleep 3
if ! kill -0 "${LIVEINST_PID}" 2>/dev/null; then
    _die "liveinst exited immediately — check ${LOG}"
fi

# ── Open the WebUI in Firefox kiosk mode ──────────────────────────────────────
echo "$(date '+%T'): Opening browser → ${COCKPIT_URL}" | tee -a "${LOG}"
if command -v firefox >/dev/null 2>&1; then
    firefox --kiosk "${COCKPIT_URL}" >>"${LOG}" 2>&1 &
else
    _die "Firefox not found — cannot display installer."
fi

# ── Wait for Anaconda to finish (install complete or cancelled) ───────────────
wait "${LIVEINST_PID}" 2>/dev/null || true
echo "$(date '+%T'): Anaconda exited." | tee -a "${LOG}"
