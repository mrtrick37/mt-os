#!/usr/bin/bash
# kyth-install-launcher — Launch Anaconda WebUI installer for Kyth
#
# Starts the Anaconda backend + cockpit-ws, then opens the WebUI in a browser.
# Runs as liveuser; escalates service start via sudo.

set -euo pipefail

# ── Start Anaconda + cockpit services ─────────────────────────────────────────
sudo systemctl start cockpit.socket anaconda.service

# ── Wait for the WebUI to respond (up to 20 seconds) ─────────────────────────
echo "Waiting for Anaconda WebUI..."
for i in $(seq 1 20); do
    if curl -sf --max-time 1 http://localhost:9090/anaconda-webui/ &>/dev/null; then
        break
    fi
    sleep 1
done

# ── Open in browser ───────────────────────────────────────────────────────────
xdg-open http://localhost:9090/anaconda-webui
