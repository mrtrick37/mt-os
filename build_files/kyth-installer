# ── Browser launcher ──────────────────────────────────────────────────────────

def _is_virtualized() -> bool:
  return subprocess.run(
    ["systemd-detect-virt", "-q"],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
  ).returncode == 0


def _gui_exec_prefix() -> list[str]:
  """Run GUI apps as the desktop user when installer is elevated with sudo."""
  if os.geteuid() == 0 and os.environ.get("SUDO_USER"):
    # Avoid relying on sudo --preserve-env; some policy setups reject it.
    cmd = [
      "sudo",
      "-u",
      os.environ["SUDO_USER"],
      "env",
    ]
    for key in (
      "DISPLAY",
      "WAYLAND_DISPLAY",
      "XAUTHORITY",
      "XDG_RUNTIME_DIR",
      "DBUS_SESSION_BUS_ADDRESS",
      "XDG_SESSION_TYPE",
    ):
      val = os.environ.get(key)
      if val:
        cmd.append(f"{key}={val}")
    return cmd
  return []


def _launch_browser(url: str) -> subprocess.Popen:
  """Try chromium first, then firefox, using VM-safe rendering defaults."""
  vm = _is_virtualized()
  prefix = _gui_exec_prefix()

  chromium_flags = [
    f"--app={url}",
    "--start-maximized",
    "--no-first-run",
    "--disable-session-crashed-bubble",
    "--disable-infobars",
    # Avoid blocking on KWallet/GNOME-keyring at startup — live env has no keyring
    "--password-store=basic",
    # Skip first-launch chrome overhead not needed in a kiosk installer
    "--disable-extensions",
    "--disable-sync",
    "--disable-translate",
    "--no-default-browser-check",
  ]
  if vm:
    chromium_flags.extend([
      "--disable-gpu",
      "--disable-gpu-compositing",
      "--disable-features=UseOzonePlatform,Vulkan,VaapiVideoDecoder",
    ])

  candidates = [
    ["chromium", *chromium_flags],
    ["chromium-browser", *chromium_flags],
    ["firefox", "--new-instance", url],
  ]

  env = os.environ.copy()
  if vm:
    # Prevent fragile VM/virtual GPU stacks from hard-freezing kiosk UI.
    env.setdefault("LIBGL_ALWAYS_SOFTWARE", "1")
    env.setdefault("MESA_LOADER_DRIVER_OVERRIDE", "llvmpipe")
    env.setdefault("GALLIUM_DRIVER", "llvmpipe")

  for cmd in candidates:
    try:
      return subprocess.Popen(prefix + cmd, env=env)
    except FileNotFoundError:
      continue

  raise RuntimeError(
    "No browser found. Install chromium or firefox:\n"
    "  sudo dnf install chromium"
  )


def _show_launch_error(msg: str) -> None:
  for cmd in (
    ["kdialog", "--error", msg],
    ["zenity", "--error", "--text", msg],
  ):
    try:
      subprocess.Popen(_gui_exec_prefix() + cmd)
      return
    except FileNotFoundError:
      continue


# ── Entry point ───────────────────────────────────────────────────────────────

def main() -> None:
  import socket as _socket
  url = f"http://127.0.0.1:{PORT}"

  # If another instance already has the port, just open a browser to it.
  try:
    with _socket.create_connection(("127.0.0.1", PORT), timeout=1):
      _launch_browser(url).wait()
      return
  except Exception:
    pass

  try:
    server = ThreadingHTTPServer(("127.0.0.1", PORT), Handler)
    threading.Thread(target=server.serve_forever, daemon=True).start()

    # Brief pause to ensure the server is listening before the browser connects
    time.sleep(0.3)

    _launch_browser(url).wait()
  except Exception:
    tb = traceback.format_exc()
    with LOG_FILE.open("a") as f:
      f.write("\n=== Installer launch failure ===\n")
      f.write(tb)
    _show_launch_error(
      "Kyth installer failed to launch.\n"
      "See /var/tmp/kyth-installer.log for details."
    )
    raise


if __name__ == "__main__":
    main()
