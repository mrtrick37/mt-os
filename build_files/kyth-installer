function toggleLog() {
  const btn  = document.getElementById('log-toggle');
  const wrap = document.getElementById('log-wrap');
  const open = wrap.classList.toggle('visible');
  btn.classList.toggle('open', open);
  btn.querySelector('.log-label').textContent = open ? ' Hide install log' : ' Show install log';
  if (open) wrap.scrollTop = wrap.scrollHeight;
}

function listenSSE() {
  const log    = document.getElementById('log-wrap');
  const fill   = document.getElementById('progress-fill');
  const pct    = document.getElementById('install-pct');
  const phase  = document.getElementById('install-phase');
  const elapsed = document.getElementById('install-elapsed');
  log.innerHTML = '';

  function humanBytes(b) {
    if (b >= 1e9)  return (b / 1e9).toFixed(1) + ' GB';
    if (b >= 1e6)  return (b / 1e6).toFixed(0) + ' MB';
    if (b >= 1e3)  return (b / 1e3).toFixed(0) + ' KB';
    return b + ' B';
  }

  // Elapsed time ticker
  const startTime = Date.now();
  const ticker = setInterval(() => {
    const s = Math.floor((Date.now() - startTime) / 1000);
    const m = Math.floor(s / 60), sec = s % 60;
    elapsed.textContent = m > 0 ? `${m}m ${sec}s elapsed` : `${sec}s elapsed`;
  }, 1000);

  function setBar(v) {
    fill.style.width = v + '%';
    pct.textContent  = v + '%';
    if (v > 5) fill.classList.remove('pulsing');
  }

  const es = new EventSource('/api/stream');
  es.onmessage = e => {
    const d = JSON.parse(e.data);

    if (d.type === 'log') {
      const line = document.createElement('div');
      const t = d.text;
      if (t.startsWith('──'))         line.className = 'log-sep';
      else if (t.startsWith('$ '))    line.className = 'log-cmd';
      else if (/error|fail/i.test(t)) line.className = 'log-err';
      line.textContent = t;
      log.appendChild(line);
      log.scrollTop = log.scrollHeight;

      // Surface key phase transitions in the phase line
      const mTotal = t.match(/layers needed:\s*(\d+)\s*\(([^)]+)\)/);
      if (mTotal) phase.textContent = `Downloading ${mTotal[1]} layers  (${mTotal[2]})`;
      if (t.includes('Deploying'))                             phase.textContent = 'Writing OS image to disk…';
      if (t.includes('Installing bootloader') || t.includes('bootupd'))
                                                               phase.textContent = 'Installing bootloader…';
      if (t.includes('Creating user'))                         phase.textContent = 'Creating user account…';
      if (t.includes('Hostname set'))                          phase.textContent = 'Applying system configuration…';

    } else if (d.type === 'stats') {
      // Real-time download stats from the backend network monitor.
      // downloaded is already capped at total by the backend.
      const totStr = humanBytes(d.total);

      // Detect transition: download done, bootc is now writing/deploying to disk.
      // Speed drops to near-zero once all bytes are received.
      if (d.downloaded >= d.total * 0.95 && d.speed < 1024 * 1024) {
        phase.textContent = 'Writing OS image to disk…';
      } else {
        const dlStr    = humanBytes(d.downloaded);
        const speedStr = humanBytes(d.speed) + '/s';
        let etaStr = '';
        if (d.eta_sec > 60)      etaStr = `  ·  ~${Math.ceil(d.eta_sec / 60)}m remaining`;
        else if (d.eta_sec > 0)  etaStr = `  ·  ~${d.eta_sec}s remaining`;
        phase.textContent = `Downloading  ${dlStr} / ${totStr}  ·  ${speedStr}${etaStr}`;
      }

    } else if (d.type === 'progress') {
      const v = d.value;
      setBar(v);
      if (v >= 90 && v < 100) phase.textContent = `Configuring system…  ${v}%`;
      else if (v >= 100)      phase.textContent = 'Complete!';

    } else if (d.type === 'done') {
      clearInterval(ticker);
      es.close();
      goto('done');
    } else if (d.type === 'error') {
      clearInterval(ticker);
      es.close();
      document.getElementById('err-msg').textContent = d.message;
      goto('error');
    }
  };
  es.onerror = () => { /* reconnects automatically */ };
}

function reboot() {
  fetch('/api/reboot', {method:'POST'});
}

