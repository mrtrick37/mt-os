  user-select: none;
}

.mode-card:hover { background: #16163a; border-color: var(--accent-lo); }

.mode-card.selected {
  border-color: var(--accent);
  background: rgba(96,96,248,.1);
  box-shadow: 0 0 0 3px rgba(96,96,248,.15);
}

.mode-card.disabled {
  opacity: .4;
  cursor: not-allowed;
  pointer-events: none;
}

.mode-radio {
  width: 18px; height: 18px;
  border-radius: 50%;
  border: 2px solid var(--border);
  flex-shrink: 0;
  margin-top: 2px;
  transition: all .15s;
}
.mode-card.selected .mode-radio {
  border-color: var(--accent);
  background: var(--accent);
  box-shadow: inset 0 0 0 3px var(--surface2);
}

.mode-body { flex: 1; }
.mode-title { font-size: 14px; font-weight: 600; color: var(--text); }
.mode-desc  { font-size: 13px; color: var(--muted); margin-top: 3px; line-height: 1.5; }

/* Alongside resize preview */
.alongside-preview {
  background: rgba(96,96,248,.06);
  border: 1px solid rgba(96,96,248,.2);
  border-radius: 8px;
  padding: 12px 14px;
  margin-top: 14px;
  font-size: 13px;
  color: var(--muted);
  display: none;
}
.alongside-preview.visible { display: block; }
.alongside-preview .preview-bar {
  display: flex;
  height: 20px;
  border-radius: 5px;
  overflow: hidden;
  margin: 10px 0 6px;
  border: 1px solid var(--border);
}
.alongside-preview .bar-existing {
  background: #1d3a6a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #93c5fd;
  flex: 1;
}
.alongside-preview .bar-kyth {
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #fff;
  font-weight: 600;
  flex: 1;
}

/* ── Warning banner ────────────────────────────────────────────────── */
.warn-box {
  background: rgba(232,160,48,.07);
  border: 1px solid rgba(232,160,48,.25);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 13px;
  color: var(--amber);
  margin-top: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ── Review table ──────────────────────────────────────────────────── */
.review-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.review-table tr { border-bottom: 1px solid var(--border); }
.review-table tr:last-child { border-bottom: none; }
.review-table td { padding: 12px 0; vertical-align: top; }
.review-table .rl { color: var(--muted); width: 140px; font-size: 13px; }
.review-table .rv { font-weight: 500; font-family: var(--mono); font-size: 13px; color: #a0a0e8; word-break: break-all; }
.review-table .rv.plain { font-family: var(--font); color: var(--text); }

/* ── Progress bar ──────────────────────────────────────────────────── */
.progress-wrap {
  margin: 6px 0 16px;
}

.progress-label {
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
}

.progress-bar {
  height: 6px;
  background: var(--surface2);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--accent-hi));
  border-radius: 3px;
  width: 0%;
  transition: width .4s var(--ease);
  box-shadow: 0 0 8px var(--accent-lo);
}

@keyframes progress-pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: .55; }
}
.progress-fill.pulsing { animation: progress-pulse 1.6s ease-in-out infinite; }

/* ── Log terminal ──────────────────────────────────────────────────── */
.log-toggle {
  background: none;
  border: none;
  color: var(--muted);
  font-size: 12px;
  cursor: pointer;
  padding: 8px 0 4px;
  text-align: left;
  display: flex;
  align-items: center;
  gap: 5px;
}
.log-toggle:hover { color: var(--fg); }
.log-toggle .arrow { display: inline-block; transition: transform 0.2s; }
.log-toggle.open .arrow { transform: rotate(90deg); }

.log-wrap {
  display: none;
  background: #080808;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow-y: auto;
  padding: 14px 16px;
  font-family: var(--mono);
  font-size: 12px;
  color: #888888;
  line-height: 1.7;
  min-height: 220px;
  max-height: 320px;
}
.log-wrap.visible { display: block; }

.log-wrap .log-sep   { color: var(--accent-lo); }
.log-wrap .log-cmd   { color: #b8b8e8; }
.log-wrap .log-err   { color: var(--red); }

/* ── Done / Error hero ─────────────────────────────────────────────── */
.hero-icon {
  font-size: 52px;
  margin-bottom: 16px;
  display: block;
}

.done-title { font-size: 28px; font-weight: 700; color: var(--green); margin-bottom: 8px; }
.err-title  { font-size: 28px; font-weight: 700; color: var(--red);   margin-bottom: 8px; }
.hero-body  { font-size: 15px; color: var(--muted); line-height: 1.65; }
.err-msg    { font-size: 13px; font-family: var(--mono); color: #e09090; background: #1a0808; border: 1px solid #4a1010; border-radius: 8px; padding: 14px; margin: 16px 0; white-space: pre-wrap; word-break: break-all; }

/* ── Scrollbar ─────────────────────────────────────────────────────── */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }
</style>
</head>

<body>
<div id="app">

  <!-- Sidebar -->
  <nav id="sidebar">
    <div class="logo">Kyth</div>
    <div class="steps" id="steps">
      <div class="step" data-step="welcome">
        <div class="step-num">1</div>
        <div class="step-label">Welcome</div>
      </div>
      <div class="step" data-step="network">
        <div class="step-num">2</div>
        <div class="step-label">Network</div>
      </div>
      <div class="step" data-step="disk">
        <div class="step-num">3</div>
        <div class="step-label">Disk</div>
      </div>
      <div class="step" data-step="config">
        <div class="step-num">4</div>
        <div class="step-label">Configure</div>
      </div>
      <div class="step" data-step="review">
        <div class="step-num">5</div>
        <div class="step-label">Review</div>
      </div>
      <div class="step" data-step="install">
        <div class="step-num">6</div>
        <div class="step-label">Install</div>
      </div>
    </div>
    <div class="sidebar-footer">kyth installer</div>
  </nav>

  <!-- Content -->
  <div id="content">

    <!-- Welcome -->
    <div class="page active" id="page-welcome">
      <div class="card">
        <div class="card-title">Welcome to Kyth</div>
        <div class="card-sub">Immutable gaming &amp; development desktop — Fedora Kinoite + CachyOS kernel</div>
        <div class="divider"></div>
        <p style="color:var(--muted);font-size:14px;line-height:1.75">
          This installer will guide you through installing Kyth on your computer.<br><br>
          <span style="color:var(--text)">What will happen:</span><br>
          &nbsp;  1. Verify your network connection<br>
          &nbsp;  2. Select an installation disk<br>
          &nbsp;  3. Choose hostname and timezone<br>
          &nbsp;  4. Download and write Kyth to disk<br><br>
          <span style="color:var(--amber)">⚠&nbsp; The selected disk will be completely erased.</span><br>
          Make sure you have backups before continuing.
        </p>
        <div class="btn-row">
          <button class="primary" onclick="goto('network')">Get Started  →</button>
        </div>
      </div>
    </div>

    <!-- Network -->
    <div class="page" id="page-network">
      <div class="card">
        <div class="card-title">Network Check</div>
        <div class="card-sub">Verifying connectivity to the Kyth container registry at ghcr.io</div>
        <div class="divider"></div>
        <div class="status-box status-info" id="net-status">Checking connection…</div>
        <div class="btn-row">
          <button onclick="goto('welcome')">←  Back</button>
          <button id="net-retry" onclick="checkNetwork()" disabled>Retry</button>
          <button id="net-next" class="primary" onclick="goto('disk')" disabled>Continue  →</button>
        </div>
      </div>
    </div>

    <!-- Disk -->
    <div class="page" id="page-disk">
      <div class="card">
        <div class="card-title">Select Installation Disk</div>
        <div class="card-sub">Choose a disk and how Kyth should be installed on it</div>
        <div class="divider"></div>
        <div class="disk-grid" id="disk-grid">
          <div class="status-box status-info">Loading disks…</div>
        </div>

        <!-- Install mode -->
        <div class="field-label" style="margin-top:20px">Installation Type</div>
        <div class="install-mode-grid">
          <div class="mode-card selected" id="mode-erase" onclick="selectMode('erase')">
            <div class="mode-radio"></div>
            <div class="mode-body">
              <div class="mode-title">Erase disk and install</div>
              <div class="mode-desc">Wipe the selected disk and install Kyth on the full disk. All existing data will be lost.</div>
            </div>
          </div>
          <div class="mode-card disabled" id="mode-alongside" onclick="selectMode('alongside')">
            <div class="mode-radio"></div>
            <div class="mode-body">
              <div class="mode-title">Install alongside existing OS</div>
              <div class="mode-desc" id="alongside-desc">Select a disk to see if alongside install is available.</div>
            </div>
          </div>
        </div>

        <!-- Alongside resize preview -->
        <div class="alongside-preview" id="alongside-preview">
          <div id="alongside-detail"></div>
          <div class="preview-bar">
            <div class="bar-existing" id="bar-existing">Existing OS (50%)</div>
            <div class="bar-kyth">Kyth (50%)</div>
          </div>
          <div id="alongside-sizes" style="font-size:12px;color:var(--muted)"></div>
        </div>

        <div class="warn-box" id="disk-warn">⚠&nbsp; All data on the selected disk will be permanently destroyed.</div>
        <div class="disk-tools">
          <button class="danger" onclick="launchGparted()">Launch GParted</button>
          <button onclick="loadDisks()">Refresh</button>
        </div>
        <div class="btn-row">
          <button onclick="goto('network')">←  Back</button>
          <button id="disk-next" class="primary" onclick="confirmDisk()" disabled>Continue  →</button>
        </div>
      </div>
    </div>

    <!-- Configure -->
    <div class="page" id="page-config">
      <div class="card">
        <div class="card-title">System Configuration</div>
        <div class="card-sub">Set hostname, timezone, and your user account for the installed system</div>
        <div class="divider"></div>
        <div class="field-label">Hostname</div>
        <input type="text" id="inp-hostname" value="kyth" maxlength="63" spellcheck="false">
        <div class="field-label">Timezone</div>
        <select id="sel-tz"></select>
        <div class="field-label" style="margin-top:18px">Username</div>
        <input type="text" id="inp-username" maxlength="32" spellcheck="false" autocomplete="off" placeholder="e.g. alice">
        <div class="field-label">Password</div>
        <input type="password" id="inp-password" autocomplete="new-password">
        <div class="field-label">Confirm Password</div>
        <input type="password" id="inp-password2" autocomplete="new-password">
        <div id="user-error" style="color:var(--red);font-size:13px;margin-top:8px;min-height:1.2em"></div>
        <div class="btn-row">
          <button onclick="goto('disk')">←  Back</button>
          <button class="primary" onclick="saveConfig()">Continue  →</button>
        </div>
      </div>
    </div>

    <!-- Review -->
    <div class="page" id="page-review">
      <div class="card">
        <div class="card-title">Review &amp; Install</div>
        <div class="card-sub">Confirm your settings — installation begins immediately after you click Install</div>
        <div class="divider"></div>
        <table class="review-table" id="review-table"></table>
        <div class="btn-row">
          <button onclick="goto('config')">←  Back</button>
          <button class="primary" onclick="startInstall()">Install Now</button>
        </div>
      </div>
    </div>

    <!-- Install -->
    <div class="page" id="page-install">
      <div class="card" style="max-width:800px">
        <div class="card-title" id="install-title">Installing Kyth…</div>
        <div class="progress-wrap">
          <div class="progress-label">
            <span id="install-phase">Preparing…</span>
            <span id="install-elapsed" style="font-size:12px;color:var(--muted);margin:0 auto"></span>
            <span id="install-pct">0%</span>
          </div>
          <div class="progress-bar">
            <div class="progress-fill pulsing" id="progress-fill"></div>
          </div>
        </div>
        <button class="log-toggle" id="log-toggle" onclick="toggleLog()">
          <span class="arrow">▶</span><span class="log-label"> Show install log</span>
        </button>
        <div class="log-wrap" id="log-wrap"></div>
      </div>
    </div>

    <!-- Done -->
    <div class="page" id="page-done">
      <div class="card" style="text-align:center;padding:56px 44px">
        <span class="hero-icon">✓</span>
        <div class="done-title">Installation Complete</div>
        <p class="hero-body">
          Kyth has been installed successfully.<br>
          Remove the installation media and reboot to start your new system.
        </p>
        <div class="btn-row" style="justify-content:center;margin-top:36px">
          <button class="primary" onclick="reboot()" style="padding:12px 36px;font-size:15px">Reboot Now</button>
        </div>
      </div>
    </div>

    <!-- Error -->
    <div class="page" id="page-error">
      <div class="card">
        <span class="hero-icon" style="font-size:40px">✗</span>
        <div class="err-title">Installation Failed</div>
        <div class="err-msg" id="err-msg"></div>
        <p style="font-size:12px;color:var(--muted)">Full log saved to /var/tmp/kyth-installer.log</p>
        <div class="btn-row">
          <button class="primary" onclick="goto('review')">←  Back to Installer</button>
        </div>
      </div>
    </div>

  </div><!-- #content -->
</div><!-- #app -->

<script>
// ── State ──────────────────────────────────────────────────────────────────
const S = {
  disk: null,        // selected disk object
  hostname: 'kyth',
  timezone: 'UTC',
  sourceImage: '',
  installMode: 'erase',   // 'erase' | 'alongside'
  alongsideInfo: null,    // { largest, disk_bytes, can_resize }
};

const STEP_ORDER = ['welcome','network','disk','config','review','install'];

// ── Navigation ─────────────────────────────────────────────────────────────
function goto(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  updateSidebar(name);
  if (name === 'network')  initNetwork();
  if (name === 'disk')     loadDisks();
  if (name === 'config')   initConfig();
  if (name === 'review')   buildReview();
}

function updateSidebar(active) {
  const idx = STEP_ORDER.indexOf(active);
  document.querySelectorAll('.step').forEach((el, i) => {
    el.classList.remove('active', 'done');
    const si = STEP_ORDER.indexOf(el.dataset.step);
    if (si < idx)      el.classList.add('done');
    else if (si === idx) el.classList.add('active');
  });
}

// ── Network ─────────────────────────────────────────────────────────────────
function initNetwork() {
  document.getElementById('net-retry').disabled = true;
  document.getElementById('net-next').disabled  = true;
  setStatus('net-status', 'info', 'Checking connection to ghcr.io…');
  checkNetwork();
}

function checkNetwork() {
  document.getElementById('net-retry').disabled = true;
  document.getElementById('net-next').disabled  = true;
  setStatus('net-status', 'info', 'Checking connection to ghcr.io…');
  fetch('/api/network').then(r => r.json()).then(d => {
    if (d.ok) {
      setStatus('net-status', 'ok', '✓  Connected — ready to download Kyth');
      document.getElementById('net-next').disabled = false;
    } else {
      setStatus('net-status', 'err',
        '✗  Cannot reach ghcr.io\n\nCheck your network connection and try again.\n' +
        'You may continue anyway — installation will fail if the registry is unreachable.');
      document.getElementById('net-retry').disabled = false;
      document.getElementById('net-next').disabled  = false;
    }
  }).catch(() => {
    setStatus('net-status', 'err', '✗  Network check failed — could not reach installer backend');
    document.getElementById('net-retry').disabled = false;
    document.getElementById('net-next').disabled  = false;
  });
}

// ── Disk ──────────────────────────────────────────────────────────────────
let _disks = [];

function loadDisks() {
  document.getElementById('disk-grid').innerHTML =
    '<div class="status-box status-info">Loading disks…</div>';
  document.getElementById('disk-next').disabled = true;
  S.disk = null;
  S.alongsideInfo = null;
  selectMode('erase');
  document.getElementById('mode-alongside').classList.add('disabled');
  document.getElementById('alongside-desc').textContent = 'Select a disk to see if alongside install is available.';
  document.getElementById('alongside-preview').classList.remove('visible');

  fetch('/api/disks').then(r => r.json()).then(disks => {
    _disks = disks;
    const grid = document.getElementById('disk-grid');
    if (!disks.length) {
      grid.innerHTML = '<div class="status-box status-err">No disks found.</div>';
      return;
    }
    grid.innerHTML = disks.map((d, i) => `
      <div class="disk-card" id="dcard-${i}" onclick="selectDisk(${i})">
        <div class="disk-icon">${d.rota ? '💿' : '💾'}</div>
        <div class="disk-info">
          <div class="disk-name">${d.name}</div>
          <div class="disk-detail">${d.model}${d.tran ? ' · ' + d.tran.toUpperCase() : ''}</div>
        </div>
        <div class="disk-size">${d.size}</div>
      </div>
    `).join('');
  }).catch(() => {
    document.getElementById('disk-grid').innerHTML =
      '<div class="status-box status-err">Failed to load disk list.</div>';
  });
}

function selectDisk(idx) {
  document.querySelectorAll('.disk-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('dcard-' + idx).classList.add('selected');
  S.disk = _disks[idx];
  document.getElementById('disk-next').disabled = false;

  // Reset alongside state while we fetch partition info
  S.alongsideInfo = null;
  const modeAlong = document.getElementById('mode-alongside');
  modeAlong.classList.add('disabled');
  document.getElementById('alongside-desc').textContent = 'Checking disk…';
  document.getElementById('alongside-preview').classList.remove('visible');
  if (S.installMode === 'alongside') selectMode('erase');

  fetch(`/api/partitions?disk=${encodeURIComponent(S.disk.name)}`)
    .then(r => r.json())
    .then(d => {
      S.alongsideInfo = d;
      if (d.can_resize && d.largest) {
        const l = d.largest;
        const halfStr = humanBytesJS(d.disk_bytes / 2);
        document.getElementById('alongside-desc').textContent =
          `Shrink "${l.name}" (${l.size}, ${l.fstype || 'unknown FS'}) to 50% and install Kyth on the freed space.`;
        modeAlong.classList.remove('disabled');
      } else {
        document.getElementById('alongside-desc').textContent =
          'No resizable partition detected on this disk.';
        modeAlong.classList.add('disabled');
      }
    })
    .catch(() => {
      document.getElementById('alongside-desc').textContent = 'Could not inspect disk partitions.';
    });
}

function humanBytesJS(b) {
  if (b >= 1e12) return (b / 1e12).toFixed(1) + ' TB';
  if (b >= 1e9)  return (b / 1e9).toFixed(1) + ' GB';
  if (b >= 1e6)  return (b / 1e6).toFixed(0) + ' MB';
  return b + ' B';
}

function selectMode(mode) {
  S.installMode = mode;
  document.getElementById('mode-erase').classList.toggle('selected', mode === 'erase');
  document.getElementById('mode-alongside').classList.toggle('selected', mode === 'alongside');

  const preview   = document.getElementById('alongside-preview');
  const warnBox   = document.getElementById('disk-warn');

  if (mode === 'alongside' && S.alongsideInfo && S.alongsideInfo.can_resize) {
    preview.classList.add('visible');
    const l        = S.alongsideInfo.largest;
    const halfStr  = humanBytesJS(S.alongsideInfo.disk_bytes / 2);
    document.getElementById('alongside-detail').textContent =
      `The partition ${l.name} (${l.size}) will be shrunk to ~${halfStr}. ` +
      `Kyth will be installed in the freed space (~${halfStr}).`;
    document.getElementById('alongside-sizes').textContent =
      `Existing OS: ~${halfStr}  ·  Kyth: ~${halfStr}`;
    document.getElementById('bar-existing').textContent = `Existing OS (~${halfStr})`;
    warnBox.innerHTML = '⚠&nbsp; The existing partition will be resized. Back up important data first.';
    warnBox.style.color = 'var(--amber)';
  } else {
    preview.classList.remove('visible');
    warnBox.innerHTML = '⚠&nbsp; All data on the selected disk will be permanently destroyed.';
    warnBox.style.color = '';
  }
}

function confirmDisk() {
  if (!S.disk) return;
  if (S.installMode === 'alongside') {
    if (!S.alongsideInfo || !S.alongsideInfo.can_resize) return;
    const l = S.alongsideInfo.largest;
    const halfStr = humanBytesJS(S.alongsideInfo.disk_bytes / 2);
    if (confirm(
      `Install Kyth alongside the existing OS on ${S.disk.name}?\n\n` +
      `  • ${l.name} (${l.size}) will be shrunk to ~${halfStr}\n` +
      `  • A new ~${halfStr} partition will be created for Kyth\n\n` +
      `Back up your data before continuing. This cannot be undone.`
    )) goto('config');
  } else {
    if (confirm(
      `This will permanently erase ALL data on:\n\n  ${S.disk.name}  —  ${S.disk.model}  (${S.disk.size})\n\nThis cannot be undone. Continue?`
    )) goto('config');
  }
}

function launchGparted() {
  fetch('/api/gparted', {method: 'POST'}).catch(() => {});
}

// ── Config ────────────────────────────────────────────────────────────────
async function initConfig() {
  const sel = document.getElementById('sel-tz');
  if (sel.options.length === 0) {
    const tzs = await fetch('/api/timezones').then(r => r.json()).catch(() => ['UTC']);
    tzs.forEach(tz => {
      const opt = document.createElement('option');
      opt.value = opt.textContent = tz;
      if (tz === 'UTC') opt.selected = true;
      sel.appendChild(opt);
    });
  }
  document.getElementById('inp-hostname').value = S.hostname;
  document.getElementById('inp-username').value = S.username || '';
  // try to find a matching TZ
  for (let i = 0; i < sel.options.length; i++) {
    if (sel.options[i].value === S.timezone) { sel.selectedIndex = i; break; }
  }
}

function saveConfig() {
  S.hostname = document.getElementById('inp-hostname').value.trim() || 'kyth';
  S.timezone = document.getElementById('sel-tz').value || 'UTC';

  const username  = document.getElementById('inp-username').value.trim();
  const password  = document.getElementById('inp-password').value;
  const password2 = document.getElementById('inp-password2').value;
  const errEl     = document.getElementById('user-error');

  if (!username) {
    errEl.textContent = 'Username is required.'; return;
  }
  if (!/^[a-z_][a-z0-9_-]{0,30}$/.test(username)) {
    errEl.textContent = 'Username must start with a letter or _ and contain only a–z, 0–9, _ or -.'; return;
  }
  if (!password) {
    errEl.textContent = 'Password is required.'; return;
  }
  if (password !== password2) {
    errEl.textContent = 'Passwords do not match.'; return;
  }

  errEl.textContent = '';
  S.username = username;
  S.password = password;
  goto('review');
}

// ── Review ────────────────────────────────────────────────────────────────
function buildReview() {
  const modeLabel = S.installMode === 'alongside'
