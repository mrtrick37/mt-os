#!/usr/bin/env python3
"""
kyth-installer — Web-based graphical installer for Kyth OS

Starts a local HTTP server, serves a polished single-page installer UI,
and launches a browser in kiosk/app mode to display it.

Install pipeline:
  1. podman pull SOURCE_IMAGE
  2. bootc install to-disk --source-imgref containers-storage:IMAGE DISK
  3. mount root partition, write hostname + timezone to ostree deploy/etc
"""

import sys
import os

import glob
import json
import subprocess
import threading
import time
import traceback
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Optional
from urllib.parse import urlparse

# ── Configuration ─────────────────────────────────────────────────────────────

SOURCE_IMAGE = os.environ.get("KYTH_SOURCE_IMAGE", "ghcr.io/mrtrick37/kyth:latest")
TARGET_IMAGE = os.environ.get("KYTH_TARGET_IMAGE", SOURCE_IMAGE)
LOG_FILE = Path(os.environ.get("KYTH_INSTALLER_LOG", "/tmp/kyth-installer.log"))
PORT = 7777

# ── Helpers ───────────────────────────────────────────────────────────────────

def list_disks() -> list[dict]:
    try:
        out = subprocess.check_output(
            ["lsblk", "--json", "--bytes", "--nodeps",
             "--output", "NAME,SIZE,MODEL,TYPE,TRAN,ROTA"],
            text=True, stderr=subprocess.DEVNULL,
        )
        result = []
        for d in json.loads(out).get("blockdevices", []):
            size = int(d.get("size", 0))
            if d.get("type") == "disk" and size > 0:
                result.append({
                    "name":   f"/dev/{d['name']}",
                    "model":  (d.get("model") or "Unknown Disk").strip(),
                    "size":   _human_size(size),
                    "bytes":  size,
                    "rota":   bool(d.get("rota")),
                    "tran":   d.get("tran") or "",
                })
        return result
    except Exception:
        return []


def _human_size(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if n < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} PB"


def list_timezones() -> list[str]:
    try:
        out = subprocess.check_output(["timedatectl", "list-timezones"], text=True)
        return [l.strip() for l in out.splitlines() if l.strip()]
    except Exception:
        return ["UTC"]


def find_deploy_etc(root_mount: str) -> Optional[str]:
    candidates = sorted(glob.glob(
        f"{root_mount}/ostree/deploy/default/deploy/*/etc"
    ))
    return candidates[-1] if candidates else None


def get_root_partition(disk: str) -> str:
    try:
        out = subprocess.check_output(
            ["lsblk", "--json", "--bytes", "--output", "NAME,SIZE,TYPE", disk],
            text=True, stderr=subprocess.DEVNULL,
        )
        parts = []
        for d in json.loads(out).get("blockdevices", []):
            for c in d.get("children", []):
                if c.get("type") == "part":
                    parts.append((int(c.get("size", 0)), c["name"]))
        if parts:
            return "/dev/" + sorted(parts, reverse=True)[0][1]
    except Exception:
        pass
    base = disk.lstrip("/dev/")
    sep = "p" if (base.startswith("nvme") or base.startswith("mmcblk")) else ""
    return f"{disk}{sep}3"


def check_network() -> bool:
    import socket
    try:
        with socket.create_connection(("ghcr.io", 443), timeout=5):
            return True
    except Exception:
        return False


def list_partitions(disk: str) -> list[dict]:
    """Return all partitions on disk with size and filesystem info."""
    try:
        out = subprocess.check_output(
            ["lsblk", "--json", "--bytes",
             "--output", "NAME,SIZE,TYPE,FSTYPE,LABEL,MOUNTPOINT"],
            text=True, stderr=subprocess.DEVNULL,
        )
        result = []
        for d in json.loads(out).get("blockdevices", []):
            if f"/dev/{d['name']}" != disk:
                continue
            for c in d.get("children", []):
                if c.get("type") != "part":
                    continue
                name = c["name"]
                num_str = ""
                for ch in reversed(name):
                    if ch.isdigit():
                        num_str = ch + num_str
                    else:
                        break
                result.append({
                    "name":       f"/dev/{name}",
                    "size":       _human_size(int(c.get("size") or 0)),
                    "bytes":      int(c.get("size") or 0),
                    "fstype":     c.get("fstype") or "",
                    "label":      c.get("label") or "",
                    "mountpoint": c.get("mountpoint") or "",
                    "num":        int(num_str) if num_str else 0,
                })
        return result
    except Exception:
        return []


def get_disk_size_bytes(disk: str) -> int:
    try:
        out = subprocess.check_output(
            ["lsblk", "--json", "--bytes", "--nodeps", "--output", "SIZE", disk],
            text=True, stderr=subprocess.DEVNULL,
        )
        return int(json.loads(out)["blockdevices"][0]["size"])
    except Exception:
        return 0


def find_efi_partition(disk: str) -> str:
    """Find the EFI System Partition (vfat, < 2 GB) on disk."""
    for p in list_partitions(disk):
        if p["fstype"].lower() == "vfat" and 0 < p["bytes"] < 2 * 1024 ** 3:
            return p["name"]
    return ""


def get_largest_data_partition(disk: str) -> Optional[dict]:
    """Return the largest non-tiny partition on disk (skips EFI / BIOS-boot)."""
    usable = [p for p in list_partitions(disk) if p["bytes"] > 600 * 1024 * 1024]
    if not usable:
        return None
    return max(usable, key=lambda p: p["bytes"])


def _as_root(cmd: list[str]) -> list[str]:
    if os.geteuid() == 0:
        return cmd
    return ["sudo", "-n", *cmd]


# ── Install state ─────────────────────────────────────────────────────────────

_state: dict = {
    "disk": "", "disk_model": "", "disk_size": "",
    "hostname": "kyth", "timezone": "UTC",
    "username": "", "password": "",
    "install_mode": "erase",  # "erase" | "alongside"
}

# Event log — append-only so late SSE connections can replay from the start.
_events: list[dict] = []
_events_lock = threading.Lock()
_new_event = threading.Condition(_events_lock)


def _push(event: dict) -> None:
    with _new_event:
        _events.append(event)
        _new_event.notify_all()


def _run_install() -> None:
    LOG_FILE.write_text("")

    def log(msg: str) -> None:
        _push({"type": "log", "text": msg})
        with LOG_FILE.open("a") as f:
            f.write(msg + "\n")

    def progress(pct: int) -> None:
        _push({"type": "progress", "value": pct})

    def _get_rx_bytes() -> int:
        """Sum RX bytes across all non-loopback interfaces from /proc/net/dev."""
        try:
            total = 0
            with open("/proc/net/dev") as f:
                for line in f:
                    if ":" not in line:
                        continue
                    iface, data = line.split(":", 1)
                    if iface.strip() == "lo":
                        continue
                    total += int(data.split()[0])
            return total
        except Exception:
            return 0

    def _parse_size_bytes(size_str: str) -> int:
        """Parse '8.3 GB' or '500 MB' to bytes. Returns 0 on failure."""
        try:
            parts = size_str.strip().split()
            value = float(parts[0])
            unit = parts[1].upper().rstrip("B") if len(parts) > 1 else ""
            mult = {"": 1, "K": 1024, "M": 1024**2, "G": 1024**3, "T": 1024**4}
            return int(value * mult.get(unit, 0))
        except Exception:
            return 0

    def run_cmd(cmd: list[str], pct_start: int, pct_end: int) -> None:
        full_cmd = _as_root(cmd)
        log(f"$ {' '.join(full_cmd)}")
        proc = subprocess.Popen(
            full_cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            text=True, bufsize=1,
        )

        # Network-byte monitor — runs in a thread while bootc downloads silently.
        # Reads /proc/net/dev every second; once we know the total download size
        # (from "layers needed: N (X.X GB)") it emits accurate byte-based progress
        # and speed/ETA stats to the frontend.
        _total_bytes:  list[int] = [0]   # parsed from "layers needed" line
        _rx_start:     list[int] = [0]   # RX bytes at moment download began
        _monitor_stop: list[bool] = [False]

        def _net_monitor():
            rx_prev = 0
            t_prev  = time.monotonic()
            speed_samples: list[float] = []

            while not _monitor_stop[0]:
                time.sleep(1)
                if _total_bytes[0] == 0 or _rx_start[0] == 0:
                    continue

                rx_now     = _get_rx_bytes()
                t_now      = time.monotonic()
                downloaded = min(_total_bytes[0], max(0, rx_now - _rx_start[0]))
                frac       = min(0.95, downloaded / _total_bytes[0])
                pct        = int(pct_start + frac * (pct_end - pct_start))
                progress(pct)

                # Rolling average speed over last 5 samples
                dt = t_now - t_prev
                if dt > 0 and rx_prev > 0:
                    speed_samples.append((rx_now - rx_prev) / dt)
                    if len(speed_samples) > 5:
                        speed_samples.pop(0)
                rx_prev = rx_now
                t_prev  = t_now

                if speed_samples:
                    avg_speed = sum(speed_samples) / len(speed_samples)
                    remaining_bytes = max(0, _total_bytes[0] - downloaded)
                    eta_sec = int(remaining_bytes / avg_speed) if avg_speed > 0 else 0
                    _push({"type": "stats",
                           "downloaded": downloaded,
                           "total":      _total_bytes[0],
                           "speed":      int(avg_speed),
                           "eta_sec":    eta_sec})

        monitor_thread = threading.Thread(target=_net_monitor, daemon=True)
        monitor_thread.start()

        for line in proc.stdout:
            stripped = line.rstrip()
            log(stripped)
            # Parse "layers needed: N (X.X GB)" — kick off byte-based monitoring
            if "layers needed:" in stripped:
                try:
                    m = stripped.split("layers needed:")[1]
                    size_str = m.split("(")[1].rstrip(")") if "(" in m else ""
                    _total_bytes[0] = _parse_size_bytes(size_str)
                    _rx_start[0]    = _get_rx_bytes()
                except Exception:
                    pass

        _monitor_stop[0] = True
        monitor_thread.join(timeout=2)
        proc.wait()
        if proc.returncode != 0:
            raise RuntimeError(
              f"Command failed (exit {proc.returncode}):\n  {' '.join(full_cmd)}"
            )
        progress(pct_end)

    if _state.get("install_mode") == "alongside":
        _run_alongside(log, progress, run_cmd)
        return

    try:
        disk = _state["disk"]
        log(f"Source image : {SOURCE_IMAGE}")
        log(f"Target image : {TARGET_IMAGE}")
        log(f"Disk         : {disk}")
        log("")

        log("── Phase 1: Pulling and writing OS image to disk ─────────────")
        log("    (bootc streams directly from registry to disk — no RAM copy)")
        run_cmd([
            "bootc", "install", "to-disk",
            "--source-imgref", f"docker://{SOURCE_IMAGE}",
            "--target-imgref", TARGET_IMAGE,
            "--filesystem", "btrfs",
            "--generic-image",
            "--skip-fetch-check",
            "--wipe",
            disk,
        ], 5, 90)

        log("── Phase 3: Configuring system ────────────────────────────────")
        progress(91)
        root_part = get_root_partition(disk)
        mount = "/var/tmp/kyth-install-root"
        Path(mount).mkdir(parents=True, exist_ok=True)
        subprocess.run(_as_root(["mount", root_part, mount]), check=True)
        progress(93)
        try:
            etc = find_deploy_etc(mount)
            if etc:
                subprocess.run(
                    _as_root(["/usr/bin/tee", str(Path(etc, "hostname"))]),
                    input=f"{_state['hostname']}\n",
                    text=True,
                    stdout=subprocess.DEVNULL,
                    check=True,
                )
                log(f"Hostname set: {_state['hostname']}")
                ltime = Path(etc, "localtime")
                subprocess.run(
                    _as_root(["ln", "-snf", f"/usr/share/zoneinfo/{_state['timezone']}", str(ltime)]),
                    check=True,
                )
                log(f"Timezone set: {_state['timezone']}")
                progress(95)

                # ── User account ──────────────────────────────────────────────
                username = _state.get("username", "").strip()
                password = _state.get("password", "")
                if username and password:
                    deploy_root = str(Path(etc).parent)
                    log(f"Creating user: {username}")
                    try:
                        # useradd --root operates on the target /etc directly —
                        # no chroot needed, no bind mounts, no PAM issues.
                        # -M: skip home dir creation (we create it manually below
                        #     because the deploy's /var symlink breaks in a chroot)
                        subprocess.run(
                            _as_root([
                                "useradd", "--root", deploy_root,
                                "-M",
                                "-G", "wheel,video,audio,render",
                                "-s", "/bin/bash",
                                username,
                            ]),
                            check=True,
                        )

                        # Hash password with openssl — avoids PAM/chpasswd issues
                        hash_r = subprocess.run(
                            ["openssl", "passwd", "-6", "-stdin"],
                            input=password, text=True,
                            capture_output=True, check=True,
                        )
                        pw_hash = hash_r.stdout.strip()

                        # Write hash into deploy's /etc/shadow via direct Python
                        # string manipulation — avoids sed regex edge-cases with
                        # '$' characters in the hash and shadow file format quirks.
                        shadow_path = f"{etc}/shadow"
                        cat_r = subprocess.run(
                            _as_root(["cat", shadow_path]),
                            capture_output=True, text=True, check=True,
                        )
                        new_shadow_lines = []
                        hash_written = False
                        for line in cat_r.stdout.splitlines(keepends=True):
                            if line.startswith(f"{username}:"):
                                fields = line.split(":")
                                fields[1] = pw_hash
                                new_shadow_lines.append(":".join(fields))
                                hash_written = True
                            else:
                                new_shadow_lines.append(line)
                        if not hash_written:
                            raise RuntimeError(
                                f"User '{username}' not found in {shadow_path} "
                                "after useradd — password NOT set"
                            )
                        subprocess.run(
                            _as_root(["tee", shadow_path]),
                            input="".join(new_shadow_lines), text=True,
                            stdout=subprocess.DEVNULL, check=True,
                        )

                        # Resolve UID/GID from the written passwd entry
                        uid, gid = "1000", "1000"
                        cat_r = subprocess.run(
                            _as_root(["cat", f"{etc}/passwd"]),
                            capture_output=True, text=True,
                        )
                        for line in cat_r.stdout.splitlines():
                            if line.startswith(f"{username}:"):
                                parts = line.split(":")
                                uid, gid = parts[2], parts[3]
                                break

                        # Create home at the ostree stateroot var — this is where
                        # /home/user resolves to on the running bootc system
                        var_home = Path(mount) / "ostree/deploy/default/var/home" / username
                        subprocess.run(_as_root(["mkdir", "-p", str(var_home)]), check=True)
                        subprocess.run(_as_root(["chown", f"{uid}:{gid}", str(var_home)]), check=True)
                        subprocess.run(_as_root(["chmod", "700", str(var_home)]), check=True)

                        # Populate from skeleton
                        skel = Path(deploy_root) / "etc/skel"
                        if skel.exists():
                            subprocess.run(
                                _as_root(["cp", "-rT", str(skel), str(var_home)]),
                                check=True,
                            )
                            subprocess.run(
                                _as_root(["chown", "-R", f"{uid}:{gid}", str(var_home)]),
                                check=True,
                            )

                        log(f"User '{username}' created (uid={uid})")
                        progress(97)
                    except Exception as ue:
                        log(f"Warning: user creation failed: {ue}")
                        log("Create a user after first boot: sudo useradd -m -G wheel USERNAME")
            else:
                log("Warning: deploy/etc not found — skipping configuration")
        finally:
            subprocess.run(_as_root(["sync"]), check=False)
            progress(99)
            subprocess.run(_as_root(["umount", mount]), check=False)

        progress(100)
        _push({"type": "done"})

    except Exception as exc:
        tb = traceback.format_exc()
        try:
            with LOG_FILE.open("a") as f:
                f.write(tb)
        except Exception:
            pass
        _push({"type": "error", "message": str(exc)})


def _run_alongside(log, progress, run_cmd) -> None:
    """Install Kyth alongside an existing OS by shrinking the largest partition."""
    try:
        disk = _state["disk"]
        log(f"Source image : {SOURCE_IMAGE}")
        log(f"Target image : {TARGET_IMAGE}")
        log(f"Disk         : {disk}")
        log(f"Install mode : alongside")
        log("")

        # ── Phase 0: Resize existing partition ────────────────────────────
        log("── Phase 0: Shrinking existing partition ──────────────────────")
        progress(2)

        disk_size = get_disk_size_bytes(disk)
        half_bytes = disk_size // 2
        half_mb = half_bytes // (1024 * 1024)

        # Read partition table once — sfdisk gives us start positions so we can
        # ignore any partition already sitting in the second half of the disk
        # (which would be a Kyth partition from a prior attempt).
        sfdisk_raw = subprocess.check_output(
            _as_root(["sfdisk", "--json", disk]),
            text=True, stderr=subprocess.DEVNULL,
        )
        sfdisk_table  = json.loads(sfdisk_raw)["partitiontable"]
        sector_size   = int(sfdisk_table.get("sectorsize", 512))
        sfdisk_parts  = sfdisk_table["partitions"]
        lsblk_by_name = {p["name"]: p for p in list_partitions(disk)}

        candidates = []
        for p in sfdisk_parts:
            start_b = p["start"] * sector_size
            size_b  = p["size"]  * sector_size
            if start_b < half_bytes and size_b > 600 * 1024 * 1024:
                candidates.append({
                    "node":       p["node"],
                    "start_b":    start_b,
                    "size_b":     size_b,
                    "fstype":     lsblk_by_name.get(p["node"], {}).get("fstype", ""),
                })

        if not candidates:
            raise RuntimeError(
                "No resizable partition found in the first half of the disk. "
                "If a previous attempt left partial changes, use GParted to "
                "restore the original layout before retrying."
            )

        target   = max(candidates, key=lambda p: p["size_b"])
        part_dev = target["node"]
        fstype   = (target["fstype"] or "").lower()
        num_str  = ""
        for ch in reversed(part_dev):
            if ch.isdigit():
                num_str = ch + num_str
            else:
                break
        part_num = int(num_str) if num_str else 0
        start_mib = target["start_b"] // (1024 * 1024)

        log(f"Target partition  : {part_dev}  ({_human_size(target['size_b'])})  "
            f"fstype={fstype or 'unknown'}")
        log(f"Disk size         : {_human_size(disk_size)}")
        log(f"Shrinking to      : ~{_human_size(half_bytes)} ({half_mb} MiB)")
        tmp_mnt  = "/var/tmp/kyth-resize-tmp"
        Path(tmp_mnt).mkdir(parents=True, exist_ok=True)

        if fstype == "btrfs":
            # Unmount by both device and mountpoint — the live desktop automounter
            # (udisks2/KDE) may have already mounted the partition elsewhere.
            subprocess.run(_as_root(["umount", "-l", part_dev]), check=False)
            subprocess.run(_as_root(["umount", "-l", tmp_mnt]), check=False)
            # If a prior run shrank the btrfs but then failed to update the
            # partition table, the superblock device-size may exceed the current
            # partition size, causing mount to fail. Try to repair that first.
            log(f"Checking btrfs superblock on {part_dev}…")
            subprocess.run(
                _as_root(["btrfs", "rescue", "fix-device-size", part_dev]),
                check=False,
            )
            log(f"Mounting {part_dev} for btrfs resize…")
            mnt_r = subprocess.run(
                _as_root(["mount", part_dev, tmp_mnt]),
                capture_output=True, text=True,
            )
            if mnt_r.returncode != 0:
                err = (mnt_r.stdout + mnt_r.stderr).strip()
                raise RuntimeError(
                    f"Failed to mount {part_dev} (exit {mnt_r.returncode}): {err}\n\n"
                    "If this disk has had previous failed install attempts, use "
                    "GParted to restore the original partition layout before retrying."
                )
            try:
                # Skip resize if the filesystem is already at or below target size
                # (can happen when retrying after a partial run).
                resize_mb = half_mb - 256
                df_r = subprocess.run(
                    _as_root(["btrfs", "filesystem", "show", "--raw", tmp_mnt]),
                    capture_output=True, text=True,
                )
                # "devid ... size NNNN ..." — extract current device size in bytes
                current_size_mb = 0
                for tok in df_r.stdout.split():
                    if tok.isdigit() and int(tok) > 1024 * 1024 * 100:
                        current_size_mb = int(tok) // (1024 * 1024)
                        break

                if current_size_mb and current_size_mb <= resize_mb:
                    log(f"btrfs already at {current_size_mb} MiB (≤ target {resize_mb} MiB) — skipping resize")
                else:
                    # Balance block groups before shrinking — btrfs may have chunks
                    # allocated past the new boundary even when used space is small.
                    log("Balancing btrfs block groups (this may take a moment)…")
                    subprocess.run(
                        _as_root(["btrfs", "balance", "start",
                                  "-dusage=90", "-musage=90", tmp_mnt]),
                        check=False,  # non-fatal; resize will tell us if insufficient
                    )
                    log(f"Resizing btrfs filesystem to {resize_mb} MiB…")
                    r = subprocess.run(
                        _as_root(["btrfs", "filesystem", "resize",
                                  f"{resize_mb}M", tmp_mnt]),
                        capture_output=True, text=True,
                    )
                    if r.stdout.strip():
                        log(r.stdout.strip())
                    if r.returncode != 0:
                        raise RuntimeError(
                            f"btrfs filesystem resize failed:\n"
                            f"{(r.stdout + r.stderr).strip()}"
                        )
                    log("btrfs filesystem resize done")
            finally:
                subprocess.run(_as_root(["umount", "-l", tmp_mnt]), check=False)
        elif fstype in ("ext4", "ext3", "ext2"):
            resize_mb = half_mb - 256
            log(f"Running e2fsck on {part_dev}…")
            subprocess.run(_as_root(["e2fsck", "-f", "-y", part_dev]), check=False)
            log(f"Resizing ext filesystem to {resize_mb} MiB…")
            r = subprocess.run(
                _as_root(["resize2fs", part_dev, f"{resize_mb}M"]),
                capture_output=True, text=True,
            )
            if r.stdout.strip():
                log(r.stdout.strip())
            if r.returncode != 0:
                raise RuntimeError(
                    f"resize2fs failed:\n{(r.stdout + r.stderr).strip()}"
                )
        elif fstype == "ntfs":
            resize_mb = half_mb - 256
            log("Resizing NTFS partition…")
            r = subprocess.run(
                _as_root(["ntfsresize", "--force", "--size", f"{resize_mb}M", part_dev]),
                capture_output=True, text=True,
            )
            if r.stdout.strip():
                log(r.stdout.strip())
            if r.returncode != 0:
                raise RuntimeError(
                    f"ntfsresize failed:\n{(r.stdout + r.stderr).strip()}"
                )
        else:
            raise RuntimeError(
                f"Cannot auto-resize filesystem type '{fstype or 'unknown'}'. "
                "Use GParted to manually free space, then retry."
            )

        progress(8)

        # Use resize_mb as the partition boundary — it matches the filesystem
        # resize target (half_mb - 256) so the partition never exceeds live data.
        # For non-btrfs paths resize_mb wasn't set, so fall back to half_mb - 256.
        try:
            part_end_mib = resize_mb
        except NameError:
            part_end_mib = half_mb - 256
        log(f"Partition {part_num} starts at {start_mib} MiB → new end: {part_end_mib} MiB")

        log(f"Removing old partition table entry for partition {part_num}…")
        subprocess.run(_as_root(["parted", "-s", disk, "rm", str(part_num)]), check=True)

        log(f"Recreating partition {part_num} at new size…")
        subprocess.run(
            _as_root(["parted", "-s", disk, "mkpart", "primary", "btrfs",
                      f"{start_mib}MiB", f"{part_end_mib}MiB"]),
            check=True,
        )
        progress(10)

        log("Creating new partition in freed space…")
        subprocess.run(
            _as_root(["parted", "-s", disk, "mkpart", "primary", "btrfs",
                      f"{part_end_mib + 1}MiB", "100%"]),
            check=True,
        )
        progress(12)

        log("Informing kernel of partition table changes…")
        subprocess.run(_as_root(["partprobe", disk]), check=False)
        time.sleep(2)

        new_parts = list_partitions(disk)
        new_part  = max(new_parts, key=lambda p: p["num"])
        new_dev   = new_part["name"]
        log(f"New partition: {new_dev}")

        log(f"Formatting {new_dev} as btrfs…")
        subprocess.run(_as_root(["mkfs.btrfs", "-f", new_dev]), check=True)
        progress(15)

        # ── Phase 1: Install OS to new partition ──────────────────────────
        log("── Phase 1: Installing OS to new partition ────────────────────")
        root_mnt = "/var/tmp/kyth-alongside-root"
        Path(root_mnt).mkdir(parents=True, exist_ok=True)
        subprocess.run(_as_root(["umount", "-l", root_mnt]), check=False)
        subprocess.run(_as_root(["mount", new_dev, root_mnt]), check=True)

        efi_part = find_efi_partition(disk)
        efi_mnt  = f"{root_mnt}/boot/efi"
        if efi_part:
            log(f"Reusing EFI partition {efi_part} for bootloader…")
            subprocess.run(_as_root(["mkdir", "-p", efi_mnt]), check=True)
            subprocess.run(_as_root(["mount", efi_part, efi_mnt]), check=True)

        try:
            run_cmd([
                "bootc", "install", "to-filesystem",
                "--source-imgref", f"docker://{SOURCE_IMAGE}",
                "--target-imgref", TARGET_IMAGE,
                "--skip-fetch-check",
                "--generic-image",
                "--acknowledge-destructive",
                root_mnt,
            ], 15, 90)
        finally:
            subprocess.run(_as_root(["sync"]), check=False)
            if efi_part:
                subprocess.run(_as_root(["umount", efi_mnt]), check=False)
            subprocess.run(_as_root(["umount", root_mnt]), check=False)

        # ── Phase 2: Post-install configuration ───────────────────────────
        log("── Phase 2: Configuring installed system ──────────────────────")
        progress(91)
        subprocess.run(_as_root(["umount", "-l", root_mnt]), check=False)
        subprocess.run(_as_root(["mount", new_dev, root_mnt]), check=True)
        try:
            etc = find_deploy_etc(root_mnt)
            if etc:
                subprocess.run(
                    _as_root(["/usr/bin/tee", str(Path(etc, "hostname"))]),
                    input=f"{_state['hostname']}\n", text=True,
                    stdout=subprocess.DEVNULL, check=True,
                )
                log(f"Hostname set: {_state['hostname']}")
                subprocess.run(
                    _as_root(["ln", "-snf",
                              f"/usr/share/zoneinfo/{_state['timezone']}",
                              str(Path(etc, "localtime"))]),
                    check=True,
                )
                log(f"Timezone set: {_state['timezone']}")
                progress(95)

                username = _state.get("username", "").strip()
                password = _state.get("password", "")
                if username and password:
                    deploy_root = str(Path(etc).parent)
                    log(f"Creating user: {username}")
                    try:
                        subprocess.run(
                            _as_root([
                                "useradd", "--root", deploy_root,
                                "-M", "-G", "wheel,video,audio,render",
                                "-s", "/bin/bash", username,
                            ]),
                            check=True,
                        )
                        hash_r = subprocess.run(
                            ["openssl", "passwd", "-6", "-stdin"],
                            input=password, text=True,
                            capture_output=True, check=True,
                        )
                        pw_hash = hash_r.stdout.strip()
                        shadow_path = f"{etc}/shadow"
                        cat_r = subprocess.run(
                            _as_root(["cat", shadow_path]),
                            capture_output=True, text=True, check=True,
                        )
                        new_shadow_lines = []
                        hash_written = False
                        for line in cat_r.stdout.splitlines(keepends=True):
                            if line.startswith(f"{username}:"):
                                fields = line.split(":")
                                fields[1] = pw_hash
                                new_shadow_lines.append(":".join(fields))
                                hash_written = True
                            else:
                                new_shadow_lines.append(line)
                        if not hash_written:
                            raise RuntimeError(
                                f"User '{username}' not found in shadow after useradd"
                            )
                        subprocess.run(
                            _as_root(["tee", shadow_path]),
                            input="".join(new_shadow_lines), text=True,
                            stdout=subprocess.DEVNULL, check=True,
                        )
                        uid, gid = "1000", "1000"
                        cat_r = subprocess.run(
                            _as_root(["cat", f"{etc}/passwd"]),
                            capture_output=True, text=True,
                        )
                        for line in cat_r.stdout.splitlines():
                            if line.startswith(f"{username}:"):
                                parts = line.split(":")
                                uid, gid = parts[2], parts[3]
                                break
                        var_home = (Path(root_mnt) /
                                    "ostree/deploy/default/var/home" / username)
                        subprocess.run(_as_root(["mkdir", "-p", str(var_home)]), check=True)
                        subprocess.run(_as_root(["chown", f"{uid}:{gid}", str(var_home)]), check=True)
                        subprocess.run(_as_root(["chmod", "700", str(var_home)]), check=True)
                        skel = Path(deploy_root) / "etc/skel"
                        if skel.exists():
                            subprocess.run(_as_root(["cp", "-rT", str(skel), str(var_home)]), check=True)
                            subprocess.run(_as_root(["chown", "-R", f"{uid}:{gid}", str(var_home)]), check=True)
                        log(f"User '{username}' created (uid={uid})")
                        progress(97)
                    except Exception as ue:
                        log(f"Warning: user creation failed: {ue}")
            else:
                log("Warning: deploy/etc not found — skipping configuration")
        finally:
            subprocess.run(_as_root(["sync"]), check=False)
            progress(99)
            subprocess.run(_as_root(["umount", root_mnt]), check=False)

        # ── Phase 3: GRUB dual-boot entries for other OSes ────────────────
        log("── Phase 3: Updating GRUB for dual-boot ──────────────────────")
        if efi_part:
            efi_scan_mnt = "/var/tmp/kyth-efi-scan"
            Path(efi_scan_mnt).mkdir(parents=True, exist_ok=True)
            subprocess.run(_as_root(["mount", efi_part, efi_scan_mnt]), check=False)
            try:
                efi_dir = Path(efi_scan_mnt) / "EFI"
                # Kyth uses EFI/fedora; skip that and the standard fallback dir.
                skip_dirs = {"fedora", "BOOT", "boot"}
                other_loaders: list[tuple[str, str]] = []
                if efi_dir.exists():
                    for d in sorted(efi_dir.iterdir()):
                        if not d.is_dir() or d.name in skip_dirs:
                            continue
                        for loader in ("shimx64.efi", "grubx64.efi",
                                       "bootmgfw.efi", "bootx64.efi"):
                            if (d / loader).exists():
                                other_loaders.append((d.name, loader))
                                break

                if other_loaders:
                    uuid_r = subprocess.run(
                        _as_root(["blkid", "-s", "UUID", "-o", "value", efi_part]),
                        capture_output=True, text=True,
                    )
                    efi_uuid = uuid_r.stdout.strip()

                    custom = ""
                    for dir_name, loader_file in other_loaders:
                        if dir_name.lower() == "microsoft":
                            label = "Windows Boot Manager"
                        else:
                            label = f"{dir_name} (chainload)"
                        efi_path = f"/EFI/{dir_name}/{loader_file}"
                        custom += (
                            f'\nmenuentry "{label}" {{\n'
                            f'    insmod fat\n'
                            f'    insmod chain\n'
                            f'    search --no-floppy --set=root --fs-uuid {efi_uuid}\n'
                            f'    chainloader {efi_path}\n'
                            f'}}\n'
                        )
                        log(f"Adding GRUB entry: {label} → {efi_path}")

                    subprocess.run(_as_root(["mount", new_dev, root_mnt]), check=False)
                    try:
                        grub_cfg = Path(root_mnt) / "boot/grub2/grub.cfg"
                        if grub_cfg.exists():
                            subprocess.run(
                                _as_root(["tee", "-a", str(grub_cfg)]),
                                input=custom, text=True,
                                stdout=subprocess.DEVNULL, check=True,
                            )
                            log(f"Added {len(other_loaders)} dual-boot entry/entries to grub.cfg")
                        else:
                            log(f"Warning: {grub_cfg} not found — skipping dual-boot entries")
                    finally:
                        subprocess.run(_as_root(["umount", root_mnt]), check=False)
                else:
                    log("No other EFI loaders found — single-boot")
            finally:
                subprocess.run(_as_root(["umount", efi_scan_mnt]), check=False)

        progress(100)
        _push({"type": "done"})

    except Exception as exc:
        tb = traceback.format_exc()
        try:
            with LOG_FILE.open("a") as f:
                f.write(tb)
        except Exception:
            pass
        _push({"type": "error", "message": str(exc)})


# ── HTTP Handler ──────────────────────────────────────────────────────────────

class Handler(BaseHTTPRequestHandler):
    def log_message(self, *_):
        pass  # silence access log

    # CORS header for local dev convenience
    def _cors(self) -> None:
        self.send_header("Access-Control-Allow-Origin", "*")

    def do_GET(self) -> None:
        path = urlparse(self.path).path
        if path == "/":
            self._html()
        elif path == "/api/config":
            self._json({
                "source_image": SOURCE_IMAGE,
                "target_image": TARGET_IMAGE,
            })
        elif path == "/api/disks":
            self._json(list_disks())
        elif path == "/api/timezones":
            self._json(list_timezones())
        elif path == "/api/network":
            self._json({"ok": check_network()})
        elif path == "/api/partitions":
            from urllib.parse import parse_qs
            qs = parse_qs(urlparse(self.path).query)
            disk = (qs.get("disk") or [""])[0]
            if disk:
                parts = list_partitions(disk)
                disk_bytes = get_disk_size_bytes(disk)
                largest = get_largest_data_partition(disk)
                self._json({
                    "partitions": parts,
                    "disk_bytes": disk_bytes,
                    "largest": largest,
                    "can_resize": largest is not None and bool(largest.get("fstype")),
                })
            else:
                self._json({"partitions": [], "disk_bytes": 0,
                            "largest": None, "can_resize": False})
        elif path == "/api/stream":
            self._sse()
        else:
            self.send_error(404)

    def do_POST(self) -> None:
        path = urlparse(self.path).path
        length = int(self.headers.get("Content-Length", 0))
        body = json.loads(self.rfile.read(length)) if length else {}

        if path == "/api/start":
            _state.update({
                "disk":         body.get("disk", ""),
                "disk_model":   body.get("disk_model", ""),
                "disk_size":    body.get("disk_size", ""),
                "hostname":     body.get("hostname", "kyth"),
                "timezone":     body.get("timezone", "UTC"),
                "username":     body.get("username", ""),
                "password":     body.get("password", ""),
                "install_mode": body.get("install_mode", "erase"),
            })
            # Reset event log for a fresh install attempt
            with _events_lock:
                _events.clear()
            threading.Thread(target=_run_install, daemon=True).start()
            self._json({"started": True})
        elif path == "/api/gparted":
            subprocess.Popen(_as_root(["gparted"]))
            self._json({"ok": True})
        elif path == "/api/reboot":
            subprocess.Popen(_as_root(["reboot"]))
            self._json({"ok": True})
        else:
            self.send_error(404)

    def _html(self) -> None:
        data = _HTML.encode()
        self.send_response(200)
        self._cors()
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", len(data))
        self.end_headers()
        self.wfile.write(data)

    def _json(self, data: object) -> None:
        body = json.dumps(data).encode()
        self.send_response(200)
        self._cors()
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", len(body))
        self.end_headers()
        self.wfile.write(body)

    def _sse(self) -> None:
        self.send_response(200)
        self._cors()
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("X-Accel-Buffering", "no")
        self.end_headers()

        sent = 0
        while True:
            with _new_event:
                while sent >= len(_events):
                    _new_event.wait(timeout=15)
                    if sent >= len(_events):
                        # keepalive
                        try:
                            self.wfile.write(b":ka\n\n")
                            self.wfile.flush()
                        except Exception:
                            return
                batch = _events[sent:]

            for event in batch:
                try:
                    self.wfile.write(f"data: {json.dumps(event)}\n\n".encode())
                    self.wfile.flush()
                except Exception:
                    return
                sent += 1
                if event["type"] in ("done", "error"):
                    return


