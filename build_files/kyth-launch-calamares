#!/usr/bin/bash
# kyth-launch-calamares — launch Calamares as root from the live desktop.
#
# liveuser is allowed to sudo only the narrow installer/reboot command set.
# Pass the display-related environment explicitly so the root Calamares process
# can connect to the live X11 session without granting unrestricted sudo.
exec sudo DISPLAY="${DISPLAY:-}" XAUTHORITY="${XAUTHORITY:-}" \
    WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}" \
    XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-}" \
    DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-}" \
    /usr/bin/kyth-calamares-root "$@"
