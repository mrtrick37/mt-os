#!/usr/bin/bash
# forge-install-launcher — Forge live ISO installer launcher
#
# Runs as liveuser; escalates Calamares to root.
# Disk selection happens inside the Calamares wizard (partition module).
#
# Display note: Wayland compositors reject root client connections, so we
# force Qt to use XWayland (xcb) where root access is unrestricted.

set -euo pipefail

exec sudo \
    --preserve-env=DISPLAY,WAYLAND_DISPLAY,XDG_RUNTIME_DIR,DBUS_SESSION_BUS_ADDRESS,XAUTHORITY \
    env QT_QPA_PLATFORM=xcb XDG_CONFIG_HOME=/etc \
    calamares
