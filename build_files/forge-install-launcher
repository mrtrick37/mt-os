#!/usr/bin/bash
# forge-install-launcher — Simple disk-selection GUI that runs bootc install.
#
# Runs as liveuser; escalates bootc to root via sudo.
# Uses kdialog for disk selection and progress display.

set -uo pipefail

TARGET_IMGREF="ghcr.io/mrtrick37/forge:latest"

# ── Build disk list for kdialog ───────────────────────────────────────────────
DISK_ARGS=()
while IFS= read -r disk; do
    size=$(lsblk -dno SIZE "${disk}" 2>/dev/null || echo "?")
    model=$(lsblk -dno MODEL "${disk}" 2>/dev/null | xargs || echo "Unknown")
    DISK_ARGS+=("${disk}" "${size} — ${model}")
done < <(lsblk -dpno NAME 2>/dev/null | grep -Ev 'loop|sr[0-9]')

if [[ ${#DISK_ARGS[@]} -eq 0 ]]; then
    kdialog --error "No installable disks found." --title "Forge Installer"
    exit 1
fi

DISK=$(kdialog \
    --title "Install Forge 43" \
    --menu "Select the disk to install Forge on.\n\nWARNING: The selected disk will be completely erased." \
    "${DISK_ARGS[@]}")

[[ -z "${DISK}" ]] && exit 0   # user cancelled

# ── Confirm ───────────────────────────────────────────────────────────────────
kdialog --warningyesno \
    "This will ERASE ALL DATA on ${DISK} and install Forge 43.\n\nAre you sure?" \
    --title "Confirm Installation" || exit 0

# ── Run bootc install in a terminal ──────────────────────────────────────────
konsole --noclose -e bash -c "
    echo '=== Forge 43 Installation ==='
    echo 'Target disk : ${DISK}'
    echo 'Image       : ${TARGET_IMGREF}'
    echo ''
    echo 'Pulling image and writing to disk — this will take a while...'
    echo ''
    sudo bootc install to-disk --target-imgref '${TARGET_IMGREF}' '${DISK}'
    EXIT=\$?
    echo ''
    if [[ \$EXIT -eq 0 ]]; then
        echo '=== Installation complete! ==='
        echo 'You can now reboot and remove the live media.'
    else
        echo '=== Installation FAILED (exit code \$EXIT) ==='
    fi
    read -r -p 'Press Enter to close...'
"
