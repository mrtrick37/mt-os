#!/usr/bin/bash
# forge-install-launcher — Start Anaconda WebUI and open the installer in Brave.
#
# Runs as liveuser; escalates Anaconda services to root via sudo.
# webui-cockpit-ws serves the WebUI on port 80 (localhost only).
# anaconda.service provides the installation backend.

set -uo pipefail

echo "=== Forge Installer ==="
echo ""

# Start the WebUI web server first (less likely to fail than the full backend)
echo "Starting webui-cockpit-ws.service..."
if ! sudo systemctl start webui-cockpit-ws.service 2>&1; then
    echo ""
    echo "ERROR: Could not start webui-cockpit-ws.service" >&2
    echo "Status:" >&2
    sudo systemctl status webui-cockpit-ws.service --no-pager 2>&1 || true
    read -r -p "Press Enter to exit..."
    exit 1
fi

# Start the Anaconda installation backend
echo "Starting anaconda.service..."
sudo systemctl start anaconda.service 2>&1 || {
    echo "WARNING: anaconda.service did not start cleanly (may be okay)" >&2
    sudo systemctl status anaconda.service --no-pager 2>&1 || true
}

# Give services time to bind
echo "Waiting for installer to be ready..."
for i in $(seq 1 10); do
    if curl -s --connect-timeout 1 http://127.0.0.1/ &>/dev/null; then
        echo "Ready."
        break
    fi
    echo "  ($i/10)..."
    sleep 1
done

echo ""
echo "Opening installer..."
brave-browser --no-sandbox \
    --app="http://127.0.0.1/cockpit/@localhost/anaconda-webui/index.html"
